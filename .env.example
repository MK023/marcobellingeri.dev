# Contratto delle variabili d'ambiente per il motore del numero mensile (ADR-0002).
# I VALORI vivono in Doppler (progetto marcobellingeri-dev, config dev/prd):
# locale via `doppler run -- ...`, CI via sync Doppler→GitHub Actions.
# Questo file documenta solo i NOMI. NESSUN valore reale qui.
# Tutte lato server (pipeline / Action / Worker): MAI esposte al browser.

# Firecrawl — scraping delle fonti (SOURCES)
FIRECRAWL_API_KEY=

# Anthropic — generazione delle bozze (Claude)
ANTHROPIC_API_KEY=

# Supabase — store RAG + draft/review (source of truth)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=   # solo pipeline server-side — MAI nel client
SUPABASE_ANON_KEY=           # eventuale lettura pubblica (solo righe published)

# Embedding — Voyage voyage-3 (1024 dim, deciso in B3); vector(1024) già
# allineato in supabase/migrations/0001_init.sql. Chiave Voyage (formato pa-…).
EMBEDDING_API_KEY=

# Cloudflare — deploy del sito (go-live). Token da creare in CF a go-live: lo
# scope dipende dal metodo finale (Pages vs Workers static assets, ADR-0001).
# CLOUDFLARE_ACCOUNT_ID è un identificatore, non un segreto.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
