{
  "name": "bellingeri-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "test:csp": "node --test \"test/*.test.mjs\"",
    "test:coverage": "node --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info \"test/*.test.mjs\" && sed -i.bak 's|^SF:|SF:astro-project/|' coverage/lcov.info && rm coverage/lcov.info.bak"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/anton": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@sentry/astro": "^10.65.0",
    "@sentry/cloudflare": "^10.65.0",
    "astro": "^7.0.6"
  },
  "devDependencies": {
    "wrangler": "^4.110.0"
  }
}
