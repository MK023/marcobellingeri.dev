{
  "name": "bellingeri-site",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "check": "astro check",
    "lint": "eslint .",
    "preview": "astro preview",
    "astro": "astro",
    "test": "npm run build && npm run test:csp",
    "test:csp": "node --test \"test/*.test.mjs\"",
    "test:coverage": "mkdir -p coverage && node --test --experimental-test-coverage --test-reporter=spec --test-reporter-destination=stdout --test-reporter=lcov --test-reporter-destination=coverage/lcov.info \"test/*.test.mjs\" && sed -i.bak 's|^SF:|SF:astro-project/|' coverage/lcov.info && rm coverage/lcov.info.bak"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/anton": "^5.2.7",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/source-serif-4": "^5.2.9",
    "@sentry/astro": "^10.66.0",
    "@sentry/browser": "^10.65.0",
    "@sentry/cloudflare": "^10.66.0",
    "astro": "^7.1.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^3.0.1",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "wrangler": "^4.110.0"
  }
}
