# Security & cache headers per Cloudflare (Workers static assets / Pages).
# Hosting = Cloudflare (ADR-0001). Migrati da vercel.json, che resta legacy.
/*
  Content-Security-Policy: default-src 'self'; script-src 'self' https://assets.calendly.com; style-src 'self' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' https://api.github.com; frame-src https://calendly.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'; form-action 'self'
  Strict-Transport-Security: max-age=63072000; includeSubDomains; preload
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=(), payment=(), usb=()

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/data/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
