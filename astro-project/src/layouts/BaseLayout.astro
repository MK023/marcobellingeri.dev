---
import '../styles/global.css';
// Font self-hosted (Fontsource) — nessun transfer di IP a Google (GDPR-safe),
// serviti same-origin. Pesi allineati a quelli usati in global.css.
import '@fontsource/anton/400.css'; // unico peso. Path esplicito come gli altri: l'import
// nudo del pacchetto non ha dichiarazioni di tipo (il contenuto è identico a 400.css).
import '@fontsource/source-serif-4/400.css';
import '@fontsource/source-serif-4/600.css';
import '@fontsource/source-serif-4/400-italic.css';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '@fontsource/jetbrains-mono/700.css';
import { getAbsoluteLocaleUrl, getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, defaultLang, languages, type Lang } from '../i18n/ui';
// Palette ⌘K e terminale vivono nel LAYOUT, non nelle singole pagine: il
// bottone in UtilityBar esiste ovunque, quindi ovunque deve esistere chi lo
// ascolta — su /radar e /atlas era un guscio vuoto (beccato da Marco su
// Windows: label ferma a "⌘K" perché lo script che la adatta non girava).
import CommandPalette from '../components/CommandPalette.astro';
import NeonTerminal from '../components/NeonTerminal.astro';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  // Path della pagina senza prefisso lingua (per gli hreflang). '' = home.
  path?: string;
  // La 404 non ha un URL canonico né una versione in un'altra lingua: dichiararli
  // direbbe ai motori che quella pagina esiste. Va indicizzata come "non esiste".
  noindex?: boolean;
}

const { lang = defaultLang, title, description, path = '', noindex = false } = Astro.props;

const t = useTranslations(lang);
const pageTitle = title ?? t('site.title');
const pageDescription = description ?? t('site.description');

// hreflang reciproci + x-default, tutti assoluti (site è configurato).
const canonical = getAbsoluteLocaleUrl(lang, path);
const alternates = (Object.keys(languages) as Lang[]).map((l) => ({
  hreflang: l,
  href: getAbsoluteLocaleUrl(l, path),
}));
const xDefault = getAbsoluteLocaleUrl(defaultLang, path);

// JSON-LD Person + ProfessionalService: dati statici, tutti già pubblici sul
// sito (niente telefono né data di nascita — il sito non è un CV). I crawler
// lo leggono dall'HTML sorgente senza eseguirlo, quindi la CSP nel meta non
// c'entra. Il serviceType rispecchia le card di Servizi.astro: se cambiano
// loro, cambia anche lui.
const siteRoot = new URL('/', Astro.site).href;
const jsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Person',
      '@id': `${siteRoot}#person`,
      name: 'Marco Bellingeri',
      jobTitle: 'Cloud Platform & AI Security Engineer',
      url: siteRoot,
      sameAs: ['https://github.com/MK023', 'https://www.linkedin.com/in/marco-bellingeri', 'https://aipia.it/attivita-e-progetti/verifica-socio/?token=14b392b'],
      knowsAbout: ['Cloud infrastructure', 'DevOps', 'Security', 'AI agents', 'AI Act compliance', 'AI security', 'LLM security', 'OWASP Top 10 for LLM Applications', 'Prompt injection defence', 'Supply chain security', 'SBOM', 'MITRE ATLAS', 'Secure software development with AI'],
      address: { '@type': 'PostalAddress', addressLocality: 'Casale Monferrato', addressCountry: 'IT' },
    },
    {
      '@type': 'ProfessionalService',
      '@id': `${siteRoot}#service`,
      name: 'Marco Bellingeri — Cloud & Security',
      url: siteRoot,
      provider: { '@id': `${siteRoot}#person` },
      areaServed: ['IT', 'Remote'],
      serviceType: ['Security Audit', 'Cloud & DevOps', 'Pair & Advisory', 'Web Development', 'AI Automation', 'AI & Agent Security'],
    },
  ],
});

// Banner-suggerimento lingua (SEO-safe): NESSUN redirect, solo un invito lato
// client basato su navigator.language. Reso visibile via JS (i crawler vedono
// `hidden`), la scelta/dismiss scrive il cookie override. Il redirect geo vero
// resta al Worker Cloudflare (ADR-0001 §4).
const suggestCopy: Record<Lang, { text: string; cta: string; dismiss: string }> = {
  en: { text: 'This site is also available in English.', cta: 'Read in English', dismiss: 'Dismiss' },
  it: { text: 'Questo sito è disponibile anche in italiano.', cta: 'Leggi in italiano', dismiss: 'Chiudi' },
};
const suggestTargets = (Object.keys(languages) as Lang[])
  .filter((l) => l !== lang)
  .map((l) => ({ code: l, url: getRelativeLocaleUrl(l, path || '/'), ...suggestCopy[l] }));
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <!-- viewport-fit=cover: senza, la safe-area sotto la dynamic island resta scoperta
       e il contenuto scrolla dietro l'isola senza nulla a mascherarlo. Con cover,
       env(safe-area-inset-top) diventa reale e la utility-bar sticky ci estende sopra
       il proprio sfondo opaco (vedi global.css). -->
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="robots" content={noindex ? 'noindex, follow' : 'index, follow'} />
  <meta name="theme-color" content="#FAFAF7" />
  <!-- .ico per gli user-agent che lo chiedono comunque; .svg (theme-aware) per tutti gli altri -->
  <link rel="icon" href="/favicon.ico" sizes="32x32" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  {!noindex && (
    <>
      <link rel="canonical" href={canonical} />
      {alternates.map((a) => (
        <link rel="alternate" hreflang={a.hreflang} href={a.href} />
      ))}
      <link rel="alternate" hreflang="x-default" href={xDefault} />
      <script is:inline type="application/ld+json" set:html={jsonLd} />
    </>
  )}
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:locale" content={t('og.locale')} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="marcobellingeri.dev" />
  <meta property="og:url" content={canonical} />
  <!-- WhatsApp, Telegram, LinkedIn e Slack non renderizzano HTML né SVG: senza una
       immagine raster il link condiviso resta una riga di testo. L'immagine è
       generata dalla card in public/og.png, con i font e i colori del sito.
       URL assoluto obbligatorio: i crawler non risolvono i path relativi. -->
  <meta property="og:image" content={new URL('/og.png', Astro.site).href} />
  <meta property="og:image:width" content="2400" />
  <meta property="og:image:height" content="1260" />
  <meta property="og:image:alt" content={t('og.imageAlt')} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={pageTitle} />
  <meta name="twitter:description" content={pageDescription} />
  <meta name="twitter:image" content={new URL('/og.png', Astro.site).href} />

  <!--
    Rilevamento giorno/notte eseguito PRIMA del primo paint, per evitare
    qualunque lampo di colore sbagliato al caricamento (vedi commit precedenti:
    questo bug esisteva ed è stato risolto spostando la logica qui).
    La scelta manuale salvata (localStorage `bellingeri-edition`) vince sempre;
    solo in sua assenza si calcola l'ora di Europe/Rome.
  -->
  <script is:inline>
    (function () {
      try {
        const saved = localStorage.getItem('bellingeri-edition');
        if (saved === 'night' || saved === 'day') {
          if (saved === 'night') document.documentElement.setAttribute('data-mode', 'night');
          return;
        }
      } catch {}
      try {
        const h = parseInt(
          new Date().toLocaleString('en-US', { timeZone: 'Europe/Rome', hour: '2-digit', hour12: false }),
          10
        );
        if (!(h >= 7 && h < 20)) {
          document.documentElement.setAttribute('data-mode', 'night');
        }
      } catch {}
    })();

    // Il loader va deciso QUI, prima del primo paint: una classe messa da uno script
    // differito arriverebbe a lenzuolo gia' disegnato, e lo farebbe lampeggiare a chi
    // l'ha gia' visto. Chi non l'ha visto lo vede: se ne va da solo (animazione CSS,
    // nessun JavaScript sul cammino critico).
    (function () {
      try {
        if (sessionStorage.getItem('bellingeri-loader-seen') === '1') {
          document.documentElement.setAttribute('data-loader', 'seen');
        } else {
          sessionStorage.setItem('bellingeri-loader-seen', '1');
        }
      } catch {}
    })();
  </script>

</head>
<body>
  <a href="#main-content" class="skip-link">{t('a11y.skipToContent')}</a>

  <div id="lang-suggest" class="lang-suggest mono" hidden>
    {suggestTargets.map((s) => (
      <div class="lang-suggest-row" data-lang={s.code} hidden>
        <span lang={s.code}>{s.text}</span>
        <a class="util-btn" href={s.url} data-lang={s.code} lang={s.code}>{s.cta}</a>
        <button class="util-btn" type="button" data-dismiss lang={s.code}>{s.dismiss}</button>
      </div>
    ))}
  </div>

  <div class="press-loader" id="press-loader">
    <div class="press-loader-inner">
      <div class="page-flip">
        <div class="book">
          <div class="leaf leaf-left">
            <span></span><span></span><span></span>
          </div>
          <div class="right-stack">
            <div class="leaf leaf-back">
              <span></span><span></span><span></span>
            </div>
            <div class="leaf leaf-front">
              <span></span><span></span><span></span>
            </div>
          </div>
        </div>
      </div>
      <span class="press-line mono">{t('loader.label')}</span>
    </div>
  </div>

  <slot />

  <NeonTerminal />
  <CommandPalette />

  <script>
    // Scroll-reveal per sezioni e gruppi in staggered — globale, si applica
    // a qualunque elemento .reveal / .reveal-stagger in qualsiasi componente.
    const revealEls = document.querySelectorAll('.reveal, .reveal-stagger');
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
            io.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.01, rootMargin: '0px 0px -20px 0px' }
    );
    revealEls.forEach((el) => io.observe(el));
  </script>
  <script>
    // Banner-suggerimento lingua: mostra l'invito solo se il browser preferisce
    // una lingua che offriamo, diversa da quella corrente, e se l'utente non ha
    // già scelto (cookie pref-lang). Nessun redirect → SEO-safe.
    (function () {
      function hasCookie(n: string) {
        return document.cookie.split('; ').some((c) => c.indexOf(n + '=') === 0);
      }
      if (hasCookie('pref-lang')) return;
      const current = document.documentElement.lang;
      const nav = (navigator.languages && navigator.languages[0]) || navigator.language || '';
      const base = nav.slice(0, 2).toLowerCase();
      if (!base || base === current) return;
      const banner = document.getElementById('lang-suggest');
      // `<HTMLElement>`: querySelector rende `Element`, che non ha `.hidden`.
      const row = banner && banner.querySelector<HTMLElement>('.lang-suggest-row[data-lang="' + base + '"]');
      if (!banner || !row) return;
      row.hidden = false;
      banner.hidden = false;
      const setPref = (lang: string) => {
        document.cookie = 'pref-lang=' + lang + '; path=/; max-age=31536000; SameSite=Lax; Secure';
      };
      row.querySelector('a')?.addEventListener('click', () => setPref(base));
      row.querySelector('[data-dismiss]')?.addEventListener('click', () => {
        setPref(current);
        banner.hidden = true;
      });
    })();
  </script>
  <style>
    .lang-suggest{ border-bottom:3px solid var(--ink); background:var(--paper-dark); }
    .lang-suggest-row{
      display:flex; gap:12px; align-items:center; justify-content:center;
      flex-wrap:wrap; padding:8px 24px;
      font-size:11px; letter-spacing:0.08em;
    }
  </style>
</body>
</html>
