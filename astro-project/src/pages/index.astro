---
// ponytail: placeholder di root. Il redirect geo-aware vero
// (request.cf.country + Accept-Language, crawler esenti, override via cookie)
// sarà di competenza di un Worker Cloudflare al go-live — vedi ADR-0001 §4.
// Nel frattempo un meta-refresh statico evita che `/` dia 404 in dev/preview.
const fallback = '/en/';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${fallback}`} />
    <link rel="canonical" href="https://marcobellingeri.dev/en/" />
    <title>Bellingeri — Cloud & Security Edition</title>
  </head>
  <body>
    <a href={fallback}>Continue to marcobellingeri.dev →</a>
  </body>
</html>
