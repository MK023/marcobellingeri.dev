---
// In produzione `/` non arriva mai qui: worker/index.js la intercetta
// (run_worker_first) e sceglie la lingua da paese + cookie pref-lang (ADR-0001 §4).
// Questo meta-refresh serve solo dove il Worker non gira — `astro dev`/`preview` —
// per evitare che `/` dia 404.
const fallback = '/en/';
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${fallback}`} />
    <link rel="canonical" href="https://marcobellingeri.dev/en/" />
    <title>Bellingeri — Cloud & Security Edition</title>
  </head>
  <body>
    <a href={fallback}>Continue to marcobellingeri.dev →</a>
  </body>
</html>
