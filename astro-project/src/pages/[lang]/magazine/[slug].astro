---
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import UtilityBar from '../../../components/UtilityBar.astro';
import SiteFooter from '../../../components/SiteFooter.astro';
import { magazineSlug } from '../../../lib/magazine';
import type { Lang } from '../../../i18n/ui';

// Una pagina propria per ogni numero, in entrambe le lingue: è il canonical a cui
// il cross-post (dev.to via RSS) deve puntare. Senza URL stabile non c'è canonical.
export async function getStaticPaths() {
  const all = await getCollection('magazine');
  return all.map((entry) => ({
    params: { lang: entry.data.lang, slug: magazineSlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;
const lang = d.lang as Lang;
const slug = magazineSlug(entry);

const copy = {
  it: { problem: 'PROBLEMA', approach: 'APPROCCIO', result: 'RISULTATO', lesson: 'LEZIONE APPRESA', back: 'Torna al magazine' },
  en: { problem: 'PROBLEM', approach: 'APPROACH', result: 'RESULT', lesson: 'LESSON LEARNED', back: 'Back to the magazine' },
}[lang];

// Meta description: incipit del problema, troncato pulito.
const description = d.problem.length > 155 ? d.problem.slice(0, 152).trimEnd() + '…' : d.problem;
const backHref = getRelativeLocaleUrl(lang, '') + '#magazine';
---

<BaseLayout lang={lang} title={`${d.title} — Magazine`} description={description} path={`magazine/${slug}`}>
  <UtilityBar />
  <main id="main-content">
    <article class="mag-article">
      <p class="mag-cred mono">MAGAZINE · N.{String(d.number).padStart(2, '0')} · {d.month.toUpperCase()} · {d.sector}</p>
      <h1 class="mag-article-title">{d.title}</h1>
      <div class="mag-body">
        <div class="case-block"><span class="label mono">{copy.problem}</span><p>{d.problem}</p></div>
        <div class="case-block"><span class="label mono">{copy.approach}</span><p>{d.approach}</p></div>
        <div class="case-block"><span class="label mono">{copy.result}</span><p>{d.result}</p></div>
        <div class="case-block"><span class="label mono">{copy.lesson}</span><p>{d.lesson}</p></div>
      </div>
      <a class="util-btn mag-back" href={backHref}>← {copy.back}</a>
    </article>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  /* Pagina standalone: layout proprio, non erediti il flusso della home. Le
     .case-block/.label del corpo restano quelle globali (identiche alla sezione
     magazine). Lo <style> scoped viene hashato da Astro nella CSP (test:csp). */
  .mag-article{ max-width:760px; margin:0 auto; padding:56px 24px 48px; }
  .mag-article-title{
    font-family:'Anton', sans-serif; text-transform:uppercase;
    font-size:clamp(30px, 6vw, 52px); line-height:0.96;
    margin:8px 0 28px; letter-spacing:0.01em;
  }
  .mag-back{ display:inline-block; margin-top:36px; text-decoration:none; }
</style>
