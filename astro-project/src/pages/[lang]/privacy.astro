---
import type { Lang } from '../../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'it' } }];
}

const { lang } = Astro.params as { lang: Lang };

// Niente P.IVA: Marco non ne ha una (2026-07-10). Quando l'aprirà, si aggiunge qui.
const TITOLARE = 'Marco Bellingeri';
const CONTATTO = 'mkdevpy@proton.me';
const UPDATED = '2026-07-21';
const TURNSTILE_POLICY = 'https://www.cloudflare.com/turnstile-privacy-policy/';

// Body per-lingua (il resto del sito segue lo stesso pattern: body nei componenti).
const copy = {
  en: {
    title: 'Privacy Policy',
    intro:
      'This is a static personal website. It uses no tracking or analytics. The only personal data it processes is what you choose to send through the contact form. Below, exactly what happens to any data.',
    controllerH: 'Data controller',
    controller: `Controller: ${TITOLARE}. Contact: ${CONTATTO}.`,
    dataH: 'Data collected',
    data: 'If you use the contact form, the name, email and message you enter are processed to deliver your request to the controller — they are not stored on the site (see Resend and Cloudflare Turnstile below). Otherwise none directly: the site is served statically. The hosting provider (Cloudflare) may keep technical access logs (IP, user agent) for security and delivery, under its own policy.',
    cookiesH: 'Cookies',
    cookies:
      'Only one, functional and consent-exempt: `pref-lang`, which remembers your language choice. No analytics, advertising, or tracking cookies are set.',
    thirdH: 'Third-party services',
    third: [
      'Cloudflare (hosting/CDN): serves the site and may process technical logs.',
      'Cal.eu (booking): the calendar is embedded only after you explicitly click to load it. Until then your browser never contacts Cal.eu. Once loaded, booking data is processed by Cal.eu under its own policy.',
      'Resend (contact form email): when you submit the contact form, the name, email and message you provide are sent through Resend (and its sub-processor AWS SES) to deliver your request to the controller. Legal basis: legitimate interest in replying to you. Not stored on the site.',
      `Cloudflare Turnstile (contact form anti-spam): the form is protected against bots by Cloudflare Turnstile, which processes your IP address and browser signals. It is privacy-preserving (no cross-site tracking, no advertising data) and strictly necessary for security, so no consent is required. Details: ${TURNSTILE_POLICY}`,
      'Sentry (error monitoring): if the site hits a technical error, the technical details (error trace, browser type) are sent to Sentry for diagnosis. Data is processed in the EU (German region), IP collection is disabled, and nothing is used for tracking or advertising.',
      'Monthly issue pipeline (server-side, not in your browser): Firecrawl scrapes public sources, Anthropic (Claude) drafts content, Supabase stores it. Sources are public pages only; no personal data is retained.',
      'Terminal "ask" command (RAG): if you ask the terminal a question, the text you type is turned into a vector by Voyage AI, matched against the published magazine content on Supabase, and passed to Anthropic (Claude) to generate the answer. The question is not stored by this site. For observability, technical telemetry without any content (token counts, timings, a random per-visit session id) is sent to Langfuse (EU): neither the question nor the answer ever leaves for it. The form is protected by Cloudflare Turnstile and a per-IP rate limit.',
    ],
    aiH: 'AI-generated content',
    ai: 'The archive’s “monthly issue” is generated with AI assistance (Anthropic/Claude) and always reviewed by a human before publishing. Source material is limited to public pages, respecting robots.txt and terms of service.',
    aiMore: 'Full details on every AI system this site runs, and the art. 50 disclosures, are on the AI transparency page.',
    transferH: 'Non-EU transfers',
    transfer:
      'Some providers (Anthropic, Cloudflare, Resend/AWS) are US-based. Transfers rely on their respective safeguards (Standard Contractual Clauses / adequacy frameworks).',
    rightsH: 'Your rights',
    rights: `Under the GDPR you may request access, rectification, erasure, restriction, portability, or object to processing. Write to ${CONTATTO}.`,
    updated: `Last updated: ${UPDATED}`,
  },
  it: {
    title: 'Informativa Privacy',
    intro:
      'Questo è un sito personale statico. Non usa tracciamento o analytics. Gli unici dati personali che tratta sono quelli che scegli di inviare tramite il form di contatto. Qui sotto, esattamente cosa accade ai dati.',
    controllerH: 'Titolare del trattamento',
    controller: `Titolare: ${TITOLARE}. Contatto: ${CONTATTO}.`,
    dataH: 'Dati raccolti',
    data: 'Se usi il form di contatto, il nome, l’email e il messaggio che inserisci sono trattati per recapitare la tua richiesta al titolare — non sono conservati sul sito (vedi Resend e Cloudflare Turnstile più sotto). Altrimenti nessuno in modo diretto: il sito è servito staticamente. Il provider di hosting (Cloudflare) può conservare log tecnici di accesso (IP, user agent) per sicurezza ed erogazione, secondo la propria policy.',
    cookiesH: 'Cookie',
    cookies:
      'Uno solo, funzionale ed esente da consenso: `pref-lang`, che ricorda la lingua scelta. Nessun cookie di analytics, pubblicità o tracciamento.',
    thirdH: 'Servizi di terze parti',
    third: [
      'Cloudflare (hosting/CDN): serve il sito e può trattare log tecnici.',
      'Cal.eu (prenotazioni): il calendario viene incorporato solo dopo un tuo clic esplicito. Fino ad allora il browser non contatta mai Cal.eu. Una volta caricato, i dati di prenotazione sono trattati da Cal.eu secondo la sua policy.',
      'Resend (email del form di contatto): quando invii il form, il nome, l’email e il messaggio che fornisci passano da Resend (e dal suo sub-responsabile AWS SES) per recapitare la tua richiesta al titolare. Base giuridica: legittimo interesse a risponderti. Non conservati sul sito.',
      `Cloudflare Turnstile (anti-spam del form): il modulo è protetto dai bot tramite Cloudflare Turnstile, che tratta il tuo indirizzo IP e i segnali del browser. È rispettoso della privacy (nessun tracciamento cross-site, nessun dato pubblicitario) e strettamente necessario alla sicurezza, quindi non richiede consenso. Dettagli: ${TURNSTILE_POLICY}`,
      'Sentry (monitoraggio errori): se il sito incontra un errore tecnico, i dettagli tecnici (traccia dell’errore, tipo di browser) vengono inviati a Sentry per la diagnosi. I dati sono trattati in UE (region tedesca), la raccolta dell’IP è disattivata e nulla è usato per tracciamento o pubblicità.',
      'Pipeline del numero mensile (lato server, non nel tuo browser): Firecrawl fa scraping di fonti pubbliche, Anthropic (Claude) redige le bozze, Supabase le archivia. Le fonti sono solo pagine pubbliche; nessun dato personale viene conservato.',
      'Comando "ask" del terminale (RAG): se fai una domanda al terminale, il testo che digiti viene trasformato in vettore da Voyage AI, confrontato con i contenuti pubblicati del magazine su Supabase e passato ad Anthropic (Claude) per generare la risposta. La domanda non viene salvata da questo sito. Per l\'osservabilità, una telemetria tecnica senza alcun contenuto (conteggi di token, tempi, un id di sessione casuale per visita) va a Langfuse (UE): né la domanda né la risposta partono mai verso di essa. Il form è protetto da Cloudflare Turnstile e da un limite di richieste per IP.',
    ],
    aiH: 'Contenuti generati con AI',
    ai: 'Il “numero mensile” dell’archivio è generato con assistenza AI (Anthropic/Claude) e sempre revisionato da una persona prima della pubblicazione. Le fonti sono limitate a pagine pubbliche, nel rispetto di robots.txt e termini di servizio.',
    aiMore: 'Il dettaglio completo di ogni sistema di IA che il sito usa, con le disclosure dell’art. 50, è nella pagina di trasparenza AI.',
    transferH: 'Trasferimenti extra-UE',
    transfer:
      'Alcuni fornitori (Anthropic, Cloudflare, Resend/AWS) hanno sede negli USA. I trasferimenti si basano sulle rispettive garanzie (Clausole Contrattuali Standard / framework di adeguatezza).',
    rightsH: 'I tuoi diritti',
    rights: `Ai sensi del GDPR puoi richiedere accesso, rettifica, cancellazione, limitazione, portabilità od opporti al trattamento. Scrivi a ${CONTATTO}.`,
    updated: `Ultimo aggiornamento: ${UPDATED}`,
  },
}[lang];
---

<BaseLayout lang={lang} title={copy.title} path="privacy">
  <main id="main-content" class="legal-page">
    <h1 class="display">{copy.title}</h1>
    <p class="legal-intro">{copy.intro}</p>

    <h2>{copy.controllerH}</h2>
    <p>{copy.controller}</p>

    <h2>{copy.dataH}</h2>
    <p>{copy.data}</p>

    <h2>{copy.cookiesH}</h2>
    <p>{copy.cookies}</p>

    <h2>{copy.thirdH}</h2>
    <ul>
      {copy.third.map((item) => <li>{item}</li>)}
    </ul>

    <h2>{copy.aiH}</h2>
    <p>{copy.ai}</p>
    <p><a href={getRelativeLocaleUrl(lang, 'ai')}>{copy.aiMore}</a></p>

    <h2>{copy.transferH}</h2>
    <p>{copy.transfer}</p>

    <h2>{copy.rightsH}</h2>
    <p>{copy.rights}</p>

    <p class="legal-updated mono">{copy.updated}</p>
  </main>
</BaseLayout>

<style>
  .legal-page{ max-width:70ch; margin:0 auto; padding:64px 24px; }
  .legal-page h1{ margin-bottom:16px; }
  .legal-page h2{ margin:32px 0 8px; font-size:18px; }
  .legal-page p, .legal-page li{ line-height:1.6; }
  .legal-page ul{ padding-left:20px; }
  .legal-page li{ margin-bottom:8px; }
  .legal-intro{ opacity:0.8; }
  .legal-updated{ margin-top:40px; font-size:12px; opacity:0.6; }
</style>
