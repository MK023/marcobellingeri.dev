---
import type { Lang } from '../../i18n/ui';
import { getRelativeLocaleUrl } from 'astro:i18n';
import BaseLayout from '../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'it' } }];
}

const { lang } = Astro.params as { lang: Lang };

// Pagina di trasparenza AI (art. 50 AI Act, applicabile dal 2 agosto 2026).
// Stessa filosofia della sezione Security: dimostrare, non dichiarare — ogni
// affermazione punta al posto vivo dove la si può verificare.
const CONTATTO = 'mkdevpy@proton.me';
const UPDATED = '2026-07-22';

// Il giudice vive nella CI, non sul sito: l'unico posto dove lo si verifica è
// il workflow nel repo pubblico. La pagina promette «ogni voce linka il punto
// dove puoi verificarla» — vale anche quando il punto è su GitHub.
const JUDGE_URL =
  'https://github.com/MK023/marcobellingeri.dev/blob/main/.github/workflows/magazine-judge.yml';

const privacyUrl = getRelativeLocaleUrl(lang, 'privacy');
const magazineUrl = getRelativeLocaleUrl(lang, '') + '#magazine';
const terminalUrl = getRelativeLocaleUrl(lang, '') + '#contact';
const radarUrl = getRelativeLocaleUrl(lang, 'radar');

const copy = {
  it: {
    title: 'Trasparenza AI',
    intro:
      'Dal 2 agosto 2026 si applica l’articolo 50 dell’AI Act europeo: chi usa sistemi di IA che parlano con le persone o generano contenuti deve dirlo, in modo chiaro e al primo contatto. Questa pagina elenca dove questo sito usa l’IA, cosa fa ogni sistema, quali dati tocca e dove sta la disclosure. Non in astratto: ogni voce linka il punto del sito dove puoi verificarla.',
    systemsH: 'Dove questo sito usa l’IA',
    systems: [
      {
        name: 'Il terminale (comando ask)',
        what: 'Rispondi a una domanda sui contenuti del magazine con una risposta generata da Claude (Anthropic), basata solo sui numeri pubblicati e sempre accompagnata dalle citazioni delle fonti.',
        data: 'La domanda che digiti viene trasformata in vettore da Voyage AI, confrontata con i contenuti pubblicati su Supabase e passata a Claude per la risposta. Non viene salvata da questo sito; l’osservabilità (Langfuse, UE) riceve solo numeri — token, tempi, esiti — mai i testi. Il form è protetto da Turnstile e da un limite di richieste per IP.',
        disclosure: 'Ogni risposta include la dicitura «Risposta generata da IA sui numeri del magazine, con citazioni (AI Act art. 50)» nel payload, visibile nel terminale.',
        link: terminalUrl,
        linkLabel: 'Apri il terminale →',
      },
      {
        name: 'Il magazine mensile',
        what: 'Un caso al mese di IA applicata sul lavoro. La bozza la scrive una pipeline (sourcing da fonti primarie, verifica delle fonti, stesura con Claude), ma nessun numero esce senza revisione e approvazione umana: il blocco è nel database, non in una policy.',
        data: 'Solo pagine pubbliche come fonti; nessun dato personale. La pipeline gira lato server, non nel tuo browser.',
        disclosure: 'Ogni numero porta l’etichetta «Generato con IA, revisionato da una persona» sulla sua pagina. La responsabilità editoriale è di Marco Bellingeri.',
        link: magazineUrl,
        linkLabel: 'Vai al magazine →',
      },
      {
        name: 'Il giudice del magazine (LLM-as-a-judge)',
        what: 'Prima che un numero arrivi sotto gli occhi di una persona, Claude lo legge e gli dà un voto su cinque criteri, seguendo una rubrica scritta prima e uguale per ogni numero. Non pubblica e non boccia da solo: viene prima della revisione umana, non al posto suo.',
        data: 'Legge solo il testo del numero in lavorazione, in italiano e in inglese, già destinato alla pubblicazione. Nessun dato personale, nessun dato dei visitatori. Gira lato server insieme al resto della pipeline, non nel tuo browser.',
        disclosure: 'Il voto e le motivazioni restano pubblici sulla proposta di modifica del numero. Se qualcuno prova a nascondere istruzioni per il modello dentro il testo del caso, quel numero prende il voto minimo: anche qui l’output del modello è trattato come input non fidato.',
        link: JUDGE_URL,
        linkLabel: 'Guarda il giudice nel repo →',
      },
      {
        name: 'Il monitor di visibilità',
        what: 'Uno script interno che misura come il sito compare nei motori di ricerca e nelle risposte degli assistenti IA (Google Search Console, Perplexity). Produce un report privato: non genera contenuti pubblici e non prende decisioni.',
        data: 'Nessun dato dei visitatori: interroga servizi esterni sul sito stesso.',
        disclosure: 'Nessuna richiesta dall’art. 50: non interagisce con persone e non pubblica contenuti. È qui per completezza.',
        link: null,
        linkLabel: null,
      },
    ],
    noAiH: 'Il Radar non usa l’IA (e va detto)',
    noAi:
      'Il globo dei bollettini sembra il posto più probabile dove trovare un modello, e invece non ne ha nessuno. Scarica i comunicati pubblici delle agenzie di sicurezza, li ripulisce e li mette sulla mappa: quello che leggi è il titolo scritto dall’agenzia, con il link al suo bollettino. Nessun modello lo riassume e nessuno lo riscrive. Su un sito che parla di sicurezza dell’IA, dire dove l’IA non c’è vale quanto dire dove c’è.',
    noAiLink: 'Apri il Radar →',
    builtH: 'Come è costruito il sito',
    built:
      'Il sito è sviluppato in pair programming con Claude Code: il codice nasce da una collaborazione umano-IA, con revisione umana su ogni modifica e gate automatici di test e sicurezza prima di ogni pubblicazione. Lo dice anche il colophon in fondo alla pagina, da sempre.',
    notH: 'Dove l’IA non c’è',
    not:
      'Il form di contatto, le prenotazioni e tutto il resto del sito sono codice normale: nessuna decisione automatizzata sui visitatori, nessuna profilazione, nessun contenuto generato al volo. Cosa succede ai dati che invii lo spiega l’informativa privacy.',
    contactH: 'Domande',
    contact: `Se qualcosa non ti torna, o vuoi sapere di più su come è fatto uno di questi sistemi: ${CONTATTO}.`,
    privacyLink: 'Informativa privacy',
    updated: `Ultimo aggiornamento: ${UPDATED}`,
  },
  en: {
    title: 'AI transparency',
    intro:
      'From 2 August 2026, Article 50 of the EU AI Act applies: anyone running AI systems that talk to people or generate content has to say so, clearly and at first contact. This page lists where this site uses AI, what each system does, what data it touches and where the disclosure lives. Not in the abstract: every entry links to the place on the site where you can check it.',
    systemsH: 'Where this site uses AI',
    systems: [
      {
        name: 'The terminal (ask command)',
        what: 'You ask a question about the magazine and get an answer generated by Claude (Anthropic), grounded only in the published issues and always accompanied by source citations.',
        data: 'The question you type is turned into a vector by Voyage AI, matched against the published content on Supabase and passed to Claude for the answer. This site does not store it; observability (Langfuse, EU) receives numbers only — tokens, timings, outcomes — never the texts. The form is protected by Turnstile and a per-IP rate limit.',
        disclosure: 'Every answer carries the notice "AI-generated from the magazine issues, with citations (EU AI Act art. 50)" in its payload, visible in the terminal.',
        link: terminalUrl,
        linkLabel: 'Open the terminal →',
      },
      {
        name: 'The monthly magazine',
        what: 'One real case of applied AI per month. A pipeline writes the draft (sourcing from primary sources, source verification, drafting with Claude), but no issue ships without human review and approval: the block lives in the database, not in a policy document.',
        data: 'Public pages only as sources; no personal data. The pipeline runs server-side, not in your browser.',
        disclosure: 'Every issue carries the label "AI-generated, human-reviewed" on its page. Editorial responsibility rests with Marco Bellingeri.',
        link: magazineUrl,
        linkLabel: 'Go to the magazine →',
      },
      {
        name: 'The magazine judge (LLM-as-a-judge)',
        what: 'Before an issue reaches human eyes, Claude reads it and scores it against five criteria, following a rubric written up front and applied the same way to every issue. It publishes nothing and rejects nothing on its own: it comes before human review, not instead of it.',
        data: 'It reads only the text of the issue being worked on, in Italian and English, already meant for publication. No personal data, no visitor data. It runs server-side with the rest of the pipeline, not in your browser.',
        disclosure: 'The score and the reasoning stay public on the issue’s change request. If someone tries to hide instructions for the model inside the case text, that issue gets the lowest score: here too, model output is treated as untrusted input.',
        link: JUDGE_URL,
        linkLabel: 'See the judge in the repo →',
      },
      {
        name: 'The visibility monitor',
        what: 'An internal script that measures how the site shows up in search engines and AI assistants’ answers (Google Search Console, Perplexity). It produces a private report: it generates no public content and makes no decisions.',
        data: 'No visitor data: it queries external services about the site itself.',
        disclosure: 'Nothing required by art. 50: it does not interact with people and publishes nothing. Listed here for completeness.',
        link: null,
        linkLabel: null,
      },
    ],
    noAiH: 'The Radar uses no AI (and that is worth saying)',
    noAi:
      'The globe of bulletins looks like the most likely place to find a model, and it has none. It fetches the public advisories from security agencies, cleans them up and puts them on the map: what you read is the headline the agency wrote, with a link to its own bulletin. No model summarises it and none rewrites it. On a site about AI security, saying where the AI is not is worth as much as saying where it is.',
    noAiLink: 'Open the Radar →',
    builtH: 'How the site is built',
    built:
      'The site is developed in pair programming with Claude Code: the code comes out of a human-AI collaboration, with human review on every change and automated test and security gates before anything reaches production. The colophon at the bottom of the page has said so from day one.',
    notH: 'Where there is no AI',
    not:
      'The contact form, the booking flow and everything else on the site are ordinary code: no automated decisions about visitors, no profiling, no content generated on the fly. What happens to the data you send is covered by the privacy policy.',
    contactH: 'Questions',
    contact: `If something here does not add up, or you want to know more about how any of these systems is built: ${CONTATTO}.`,
    privacyLink: 'Privacy policy',
    updated: `Last updated: ${UPDATED}`,
  },
}[lang];
---

<BaseLayout lang={lang} title={copy.title} path="ai">
  <main id="main-content" class="legal-page">
    <h1 class="display">{copy.title}</h1>
    <p class="legal-intro">{copy.intro}</p>

    <h2>{copy.systemsH}</h2>
    {copy.systems.map((s) => (
      <section class="ai-system">
        <h3>{s.name}</h3>
        <p>{s.what}</p>
        <p>{s.data}</p>
        <p>{s.disclosure}</p>
        {s.link && <a href={s.link}>{s.linkLabel}</a>}
      </section>
    ))}

    <h2>{copy.noAiH}</h2>
    <p>{copy.noAi} <a href={radarUrl}>{copy.noAiLink}</a></p>

    <h2>{copy.builtH}</h2>
    <p>{copy.built}</p>

    <h2>{copy.notH}</h2>
    <p>{copy.not} <a href={privacyUrl}>{copy.privacyLink}</a>.</p>

    <h2>{copy.contactH}</h2>
    <p>{copy.contact}</p>

    <p class="legal-updated mono">{copy.updated}</p>
  </main>
</BaseLayout>

<style>
  .legal-page{ max-width:70ch; margin:0 auto; padding:64px 24px; }
  .legal-page h1{ margin-bottom:16px; }
  .legal-page h2{ margin:32px 0 8px; font-size:18px; }
  .legal-page h3{ margin:20px 0 6px; font-size:16px; }
  .legal-page p{ line-height:1.6; margin-bottom:10px; }
  .legal-intro{ opacity:0.8; }
  .ai-system{ margin-bottom:20px; }
  .legal-updated{ margin-top:40px; font-size:12px; opacity:0.6; }
</style>
