---
import type { Lang } from '../../i18n/ui';
import BaseLayout from '../../layouts/BaseLayout.astro';
import UtilityBar from '../../components/UtilityBar.astro';
import Hero from '../../components/Hero.astro';
import Toc from '../../components/Toc.astro';
import Dossier from '../../components/Dossier.astro';
import Percorso from '../../components/Percorso.astro';
import StackSection from '../../components/StackSection.astro';
import SecurityCard from '../../components/SecurityCard.astro';
import FieldNotes from '../../components/FieldNotes.astro';
import MagazineSection from '../../components/MagazineSection.astro';
import Projects from '../../components/Projects.astro';
import Servizi from '../../components/Servizi.astro';
import Booking from '../../components/Booking.astro';
import SiteFooter from '../../components/SiteFooter.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'it' } }];
}

const { lang } = Astro.params as { lang: Lang };
---

<BaseLayout lang={lang}>
  <UtilityBar />
  <Hero />
  <Toc />

  <main id="main-content">
    <Dossier />
    <Servizi />
    <FieldNotes />
    <MagazineSection />
    <Projects />
    <Percorso />
    <StackSection />
    <SecurityCard />
    <Booking />
  </main>

  <SiteFooter />
</BaseLayout>
