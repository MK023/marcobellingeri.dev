---
import { numeroSezione } from '../lib/sections';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, defaultLang, type Lang } from '../i18n/ui';
import PortalButton from './PortalButton.astro';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

// Il portale verso il grafo di Atlas: la card qui sopra lo racconta, la
// pagina lo MOSTRA — il grafo vero della wiki, filtrato ai layer pubblicabili.
const atlas = {
  it: { label: 'Il grafo di Atlas', sub: 'la wiki vista come la vede una macchina — dal vivo' },
  en: { label: 'The Atlas graph', sub: 'the wiki as a machine sees it — live' },
}[lang];

type Project = {
  id: string;
  name: string;
  status: 'shipped' | 'active' | 'rnd';
  statusLabel: string;
  swatchClass: 'p-orange' | 'p-violet' | 'p-dark';
  summary: string;
  problem: string;
  approach: string;
  result: string;
};

// Nuovo progetto? Aggiungi un oggetto in entrambe le lingue — il markup si genera da solo.
const projects: Record<Lang, Project[]> = {
  it: [
    {
      id: 'case-torinoparking',
      name: 'TorinoParking',
      status: 'active',
      statusLabel: '→ APP STORE',
      swatchClass: 'p-orange',
      summary:
        "Torino, ora di punta: dove la lasci la macchina? Un'API che risponde in tempo reale, costruita security-first come se fosse in produzione da anni — FastAPI async, PostGIS per il geospaziale, Redis con ETag. Prossima fermata: App Store.",
      problem:
        "Sapere in tempo reale dove c'è posto a Torino significava saltare tra fonti diverse, senza un'unica API pulita e veloce da interrogare.",
      approach:
        'API security-first: FastAPI async su Python 3.12, PostgreSQL 16 + PostGIS per il geospaziale, Redis 7 con compressione e richieste condizionali ETag, HMAC-SHA256 sulle API key (zero plaintext), rate limiting sliding-window multi-tier.',
      result:
        '51 test tra unit, integration ed e2e con testcontainer, CI/CD e threat model documentato in SECURITY.md. Prossimo traguardo: portarla su Apple App Store come app nativa.',
    },
    {
      id: 'case-jobsearch',
      name: 'JobSearch',
      status: 'shipped',
      statusLabel: 'VALIDATO',
      swatchClass: 'p-violet',
      summary:
        'La caccia al lavoro con un cervello AI: legge le offerte, dà un voto secco alla compatibilità col CV (0–100), dice cosa manca davvero e scrive lettere, follow-up e domande da colloquio. Validato nel modo più onesto possibile: su di me.',
      problem:
        'Le candidature andavano a caso: stesso CV per annunci molto diversi, nessun modo onesto di misurare quali competenze mancassero davvero rispetto a un ruolo.',
      approach:
        "Architettura a microservizi (FastAPI + Nginx + PostgreSQL + Redis, con server MCP per l'agente AI). Punteggio di compatibilità, gap analysis con severity e piani d'azione, CRM recruiter — nessun abbellimento, nemmeno su se stesso.",
      result:
        'OWASP Top 10 audit completo, 342 test, mypy strict a zero errori, deploy su Fly.io con CI/CD a 8 stage. Il metodo si generalizza: funziona su qualunque CV.',
    },
    {
      id: 'case-atlas',
      name: 'Atlas',
      status: 'rnd',
      statusLabel: 'R&D',
      swatchClass: 'p-dark',
      summary:
        "L'esperimento filosofico del lotto: un knowledge graph su Obsidian che si chiede come si costruiscono memoria e identità. Accantonato come prodotto, insostituibile come strumento di pensiero — e la versione SaaS con RAG è ancora sul tavolo.",
      problem:
        'Le note sparse non si parlavano tra loro: idee, letture, progetti finivano isolati invece di connettersi.',
      approach:
        'Un grafo di conoscenza personale su Obsidian, pensato non solo come archivio ma come domanda aperta su come memoria e identità si costruiscono nel tempo.',
      result:
        "Deprioritizzato come prodotto rispetto a JobSearch, ma resta lo strumento di pensiero più usato — e l'idea di una versione SaaS con RAG resta sul tavolo.",
    },
  ],
  en: [
    {
      id: 'case-torinoparking',
      name: 'TorinoParking',
      status: 'active',
      statusLabel: '→ APP STORE',
      swatchClass: 'p-orange',
      summary:
        "Turin, rush hour: where do you leave the car? An API that answers in real time, built security-first as if it had been in production for years — async FastAPI, PostGIS for geospatial, Redis with ETags. Next stop: the App Store.",
      problem:
        "Knowing in real time where there's a free spot in Turin meant jumping between different sources, with no single clean, fast API to query.",
      approach:
        'Security-first API: async FastAPI on Python 3.12, PostgreSQL 16 + PostGIS for geospatial, Redis 7 with compression and conditional ETag requests, HMAC-SHA256 on API keys (zero plaintext), multi-tier sliding-window rate limiting.',
      result:
        '51 tests across unit, integration and e2e with testcontainers, CI/CD and a threat model documented in SECURITY.md. Next milestone: bringing it to the Apple App Store as a native app.',
    },
    {
      id: 'case-jobsearch',
      name: 'JobSearch',
      status: 'shipped',
      statusLabel: 'VALIDATED',
      swatchClass: 'p-violet',
      summary:
        "The job hunt with an AI brain: it reads listings, gives your CV a blunt fit score (0–100), tells you what's actually missing and writes the letters, follow-ups and interview questions. Validated the most honest way there is: on me.",
      problem:
        'Applications went out at random: the same CV for very different roles, with no honest way to measure which skills were actually missing for a given role.',
      approach:
        'Microservice architecture (FastAPI + Nginx + PostgreSQL + Redis, with an MCP server for the AI agent). Compatibility score, gap analysis with severity and action plans, recruiter CRM — no embellishment, not even on myself.',
      result:
        'Full OWASP Top 10 audit, 342 tests, mypy strict at zero errors, deployed on Fly.io with an 8-stage CI/CD. The method generalises: it works on any CV.',
    },
    {
      id: 'case-atlas',
      name: 'Atlas',
      status: 'rnd',
      statusLabel: 'R&D',
      swatchClass: 'p-dark',
      summary:
        "The philosophical experiment of the lot: an Obsidian knowledge graph asking how memory and identity get built over time. Shelved as a product, irreplaceable as a thinking tool — and the RAG-powered SaaS idea is still on the table.",
      problem:
        "Scattered notes didn't talk to each other: ideas, readings and projects ended up isolated instead of connected.",
      approach:
        'A personal knowledge graph on Obsidian, meant not just as an archive but as an open question about how memory and identity are built over time.',
      result:
        'Deprioritised as a product against JobSearch, but it remains the thinking tool I use most — and the idea of a SaaS version with RAG is still on the table.',
    },
  ],
};

const list = projects[lang];
const title = lang === 'en' ? 'Projects' : 'Progetti';
const labels = { problem: lang === 'en' ? 'PROBLEM' : 'PROBLEMA', approach: lang === 'en' ? 'APPROACH' : 'APPROCCIO', result: lang === 'en' ? 'RESULT' : 'RISULTATO' };
---

<section id="projects" class="reveal">
  <div class="section-head">
    <span class="num mono">{numeroSezione('projects')}</span>
    <h2 class="display">{title}</h2>
  </div>
  <div class="reviews reveal-stagger" data-details={t('proj.details')} data-close={t('proj.close')}>
    {list.map((p) => (
      <div class="review">
        <div class={`review-preview ${p.swatchClass}`} aria-hidden="true">
          <span class="swatch-label mono">{p.name.toUpperCase()}</span>
        </div>
        <button class="review-toggle" data-target={p.id} aria-expanded="false" aria-controls={p.id}>
          <div>
            <h3>{p.name}</h3>
            <span class={`status ${p.status} mono`}>{p.statusLabel}</span>
          </div>
          <span class="review-chevron mono">{t('proj.details')}</span>
        </button>
        <p>{p.summary}</p>
        <div class="review-detail" id={p.id}>
          <div class="case-block"><span class="label mono">{labels.problem}</span><p>{p.problem}</p></div>
          <div class="case-block"><span class="label mono">{labels.approach}</span><p>{p.approach}</p></div>
          <div class="case-block"><span class="label mono">{labels.result}</span><p>{p.result}</p></div>
        </div>
      </div>
    ))}
  </div>
  <PortalButton href={getRelativeLocaleUrl(lang, 'atlas')} label={atlas.label} sub={atlas.sub} />
</section>

<script>
  // ---- project case-study accordions ----
  (function projectAccordions() {
    const reviews = document.querySelector<HTMLElement>('.reviews');
    if (!reviews) return;
    const detailsLabel = reviews.dataset.details || '';
    const closeLabel = reviews.dataset.close || '';

    reviews.querySelectorAll<HTMLButtonElement>('.review-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const detail = document.getElementById(btn.dataset.target || '');
        if (!detail) return;
        const isOpen = detail.classList.contains('open');
        detail.classList.toggle('open', !isOpen);
        btn.classList.toggle('open', !isOpen);
        btn.setAttribute('aria-expanded', String(!isOpen));
        const chevron = btn.querySelector('.review-chevron');
        if (chevron) chevron.textContent = isOpen ? detailsLabel : closeLabel;
      });
    });
  })();
</script>
