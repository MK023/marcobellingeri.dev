---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { languages, defaultLang, useTranslations, type Lang } from '../i18n/ui';

const current = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(current);

// Sotto-path senza prefisso lingua → lo switcher punta alla STESSA pagina
// nell'altra lingua (per ora solo la home, ma resta corretto per rotte future).
const sub = Astro.url.pathname.replace(new RegExp(`^/${current}(?=/|$)`), '') || '/';
const langOptions = (Object.keys(languages) as Lang[]).map((l) => ({
  code: l,
  url: getRelativeLocaleUrl(l, sub),
  current: l === current,
}));
---

<div class="utility-bar mono">
  <span>{t('ub.issue')}</span>
  <span>{t('ub.place')} · <span id="live-clock">--:--:--</span></span>
  <div class="utility-actions">
    <div class="lang-switcher" role="group" aria-label="Language / Lingua">
      {langOptions.map((o) =>
        o.current ? (
          <span class="util-btn lang-opt is-current" aria-current="true" lang={o.code}>{o.code.toUpperCase()}</span>
        ) : (
          <a class="util-btn lang-opt" href={o.url} hreflang={o.code} lang={o.code} data-lang={o.code}>{o.code.toUpperCase()}</a>
        )
      )}
    </div>
    <button
      class="util-btn"
      id="edition-indicator"
      type="button"
      aria-pressed="false"
      title={t('ub.editionTitle')}
      data-day={t('ub.editionDay')}
      data-night={t('ub.editionNight')}
    >{t('ub.editionDay')}</button>
    <button class="util-btn" id="cmdk-trigger">⌘K {t('ub.commands')}</button>
    {/*
      Un vero PDF, uno per lingua, generato dai .docx e ripulito dei dati che non
      vanno su una pagina pubblica: niente cellulare, niente data di nascita, e
      l'indirizzo Proton al posto della Gmail — lo stesso che il sito espone ovunque.
      Prima questo bottone chiamava window.print() e stampava la pagina.
    */}
    <a class="util-btn" id="cv-btn" href={`/cv-${current}.pdf`} title={t('ub.cvTitle')} download>
      {t('ub.cv')}
    </a>
  </div>
</div>

<style>
  .lang-switcher{ display:flex; gap:0; }
  /* le due opzioni lingua condividono un bordo per leggersi come un segmento */
  .lang-switcher .lang-opt + .lang-opt{ border-left:none; }
  .lang-opt{ text-decoration:none; }
  /* lingua attiva = stato invertito (come l'hover di util-btn) */
  .lang-opt.is-current{ background:var(--ink); color:var(--paper); cursor:default; }
</style>

<script>
  import { dateLocale, type Lang } from '../i18n/ui';

  const lang = (document.documentElement.lang || 'en') as Lang;

  // ---- live clock (Europe/Rome) ----
  const clockEl = document.getElementById('live-clock');
  function tickClock() {
    if (!clockEl) return;
    clockEl.textContent = new Date().toLocaleTimeString(dateLocale[lang], {
      timeZone: 'Europe/Rome', hour: '2-digit', minute: '2-digit', second: '2-digit',
    });
  }
  tickClock();
  setInterval(tickClock, 1000);

  // ---- override lingua: la scelta manuale vince sul geo/IP ----
  // Memorizza la lingua scelta in un cookie che il Worker su `/`
  // (worker/index.js) rispetta prima di qualunque redirect per paese.
  document.querySelectorAll('.lang-opt[data-lang]').forEach((el) => {
    el.addEventListener('click', () => {
      const chosen = (el as HTMLElement).dataset.lang;
      document.cookie = `pref-lang=${chosen}; path=/; max-age=31536000; SameSite=Lax`;
    });
  });

  // ---- day / night edition — automatica di default, ma con override manuale ----
  // La scelta manuale è persistita in localStorage (chiave `bellingeri-edition`)
  // e VINCE sempre sull'automatismo. Senza scelta salvata resta automatica in
  // base all'ora di Europe/Rome, riallineata ogni 60s.
  const EDITION_KEY = 'bellingeri-edition';
  const editionIndicator = document.getElementById('edition-indicator');
  const labels = {
    day: editionIndicator?.dataset.day || (lang === 'en' ? '☀ DAY EDITION' : '☀ EDIZIONE GIORNO'),
    night: editionIndicator?.dataset.night || (lang === 'en' ? '☾ NIGHT EDITION' : '☾ EDIZIONE NOTTE'),
  };
  function setMode(mode: 'day' | 'night') {
    if (mode === 'night') {
      document.documentElement.setAttribute('data-mode', 'night');
      if (editionIndicator) editionIndicator.textContent = labels.night;
    } else {
      document.documentElement.removeAttribute('data-mode');
      if (editionIndicator) editionIndicator.textContent = labels.day;
    }
    // aria-pressed riflette se la notte è attiva
    editionIndicator?.setAttribute('aria-pressed', String(mode === 'night'));
  }
  function autoMode(): 'day' | 'night' {
    const hourStr = new Date().toLocaleString('en-US', { timeZone: 'Europe/Rome', hour: '2-digit', hour12: false });
    const h = parseInt(hourStr, 10);
    return h >= 7 && h < 20 ? 'day' : 'night';
  }
  function storedMode(): 'day' | 'night' | null {
    try {
      const v = localStorage.getItem(EDITION_KEY);
      return v === 'day' || v === 'night' ? v : null;
    } catch (e) { return null; }
  }

  let autoTimer: ReturnType<typeof setInterval> | undefined;
  function startAuto() {
    setMode(autoMode());
    if (autoTimer === undefined) autoTimer = setInterval(() => setMode(autoMode()), 60000);
  }
  function stopAuto() {
    if (autoTimer !== undefined) { clearInterval(autoTimer); autoTimer = undefined; }
  }

  // Stato iniziale: la scelta salvata vince, altrimenti automatico.
  const saved = storedMode();
  if (saved) setMode(saved);
  else startAuto();

  // Clic → alterna, persiste, e disattiva l'automatismo (che non deve più
  // sovrascrivere la scelta dell'utente).
  editionIndicator?.addEventListener('click', () => {
    const next: 'day' | 'night' =
      document.documentElement.getAttribute('data-mode') === 'night' ? 'day' : 'night';
    stopAuto();
    setMode(next);
    try { localStorage.setItem(EDITION_KEY, next); } catch (e) {}
  });
</script>
