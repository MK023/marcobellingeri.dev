---
import { numeroSezione } from '../lib/sections';
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { magazineSlug } from '../lib/magazine';
import Newsstand from './Newsstand.astro';
import { defaultLang, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;

const issues = (await getCollection('magazine', (c) => c.data.lang === lang)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Edicola: dove la firma di Marco esce anche fuori dal sito. Reso come una PILA
// da edicola (newsstand stack) — le firme impilate come giornali, sfalsate e
// ruotate. Solo link in uscita (nuova scheda). L'array qui sotto è la fonte:
// una firma a settimana = una riga in più, il layout regge da 2 a molti.
const DEVTO = 'https://dev.to/mk023/how-i-shipped-13-prs-in-one-afternoon-pair-programming-with-claude-and-what-i-learned-1274';
// L'articolo "audit di sé" è ospitato sul sito (casa canonical): il giornale
// punta alla pagina interna, non a dev.to.
const AUDIT = getRelativeLocaleUrl(lang, 'writing/audit-di-se');
// Devpunks non è una firma ma un talent network: sta FUORI dalla pila, come chip
// fisso a fianco dell'edicola.
const DEVPUNKS = 'https://devpunks.com';

const copy = {
  it: {
    intro: "Ogni mese un caso vero di IA applicata sul lavoro: il problema, la scelta fatta, cosa è cambiato. Lo scrive una pipeline, controllato sulle fonti. Il primo è il punto zero: le idee migliorano strada facendo.",
    toggle: 'LEGGI',
    problem: 'PROBLEMA', approach: 'APPROCCIO', result: 'RISULTATO', lesson: 'LEZIONE APPRESA',
    permalink: 'Apri la pagina →',
    edicolaHead: 'Edicola · dove la firma esce anche fuori',
    audit: 'Il sito che si audita da solo',
    auditSub: 'Sul sito · 2026',
    devto: '13 PR con Claude in un pomeriggio',
    devpunks: 'Nel talent network',
    newTab: 'si apre in una nuova scheda',
  },
  en: {
    intro: 'One real case a month of AI put to work: the problem, the call made, what changed. A pipeline writes it, checked against the sources. The first one is point zero: ideas get better as you go.',
    toggle: 'READ',
    problem: 'PROBLEM', approach: 'APPROACH', result: 'RESULT', lesson: 'LESSON LEARNED',
    permalink: 'Open the page →',
    edicolaHead: 'Edicola · where the byline also runs',
    audit: 'The site that audits itself',
    auditSub: 'On the site · 2026',
    devto: 'Shipping 13 PRs in one afternoon',
    devpunks: 'In the talent network',
    newTab: 'opens in a new tab',
  },
}[lang];

// La pila è data-driven: aggiungere una firma = aggiungere un oggetto qui.
// Il layout regge da 2 a molti (nuova firma ~1/settimana). L'etichetta riusa
// le stringhe di copy per restare bilingue; sub e href sono neutri di lingua.
const bylines = [
  { label: copy.audit, sub: copy.auditSub, href: AUDIT },
  { label: copy.devto, sub: 'dev.to · 2026', href: DEVTO },
];
---

<section id="magazine" class="reveal">
  <div class="section-head">
    <span class="num mono">{numeroSezione('magazine')}</span>
    <h2 class="display">Magazine</h2>
  </div>
  <p class="case-archive-note">{copy.intro}</p>
  <div class="mag-list">
    {issues.map((issue, i) => (
      <details class="mag-item">
        <summary class="mag-summary">
          <div class="mag-stat-col">
            {issue.data.stat != null ? (
              <div
                class="mag-stat display"
                id={`mag-stat-${i}`}
                data-target={issue.data.stat}
                data-suffix={issue.data.statSuffix ?? ''}
              >
                0{issue.data.statSuffix ?? ''}
              </div>
            ) : (
              <div class="mag-number display">N.{String(issue.data.number).padStart(2, '0')}</div>
            )}
            <span class="mag-cred mono">{issue.data.month.toUpperCase()} · {issue.data.sector}</span>
          </div>
          <div class="mag-summary-main">
            <h3 class="mag-title">{issue.data.title}</h3>
            <span class="mag-toggle mono">{copy.toggle}</span>
          </div>
        </summary>
        <div class="mag-body">
          <div class="case-block"><span class="label mono">{copy.problem}</span><p>{issue.data.problem}</p></div>
          <div class="case-block"><span class="label mono">{copy.approach}</span><p>{issue.data.approach}</p></div>
          <div class="case-block"><span class="label mono">{copy.result}</span><p>{issue.data.result}</p></div>
          <div class="case-block"><span class="label mono">{copy.lesson}</span><p>{issue.data.lesson}</p></div>
          <a class="mag-permalink mono" href={getRelativeLocaleUrl(lang, `magazine/${magazineSlug(issue)}`)}>{copy.permalink}</a>
        </div>
      </details>
    ))}
  </div>

  <div class="edicola-wrap">
    <Newsstand head={copy.edicolaHead} items={bylines} newTab={copy.newTab} />
    <a class="cert-chip edicola-devpunks" href={DEVPUNKS} target="_blank" rel="noopener">
      <span class="cert-name mono">Devpunks</span>
      <span class="cert-org mono">{copy.devpunks}</span>
    </a>
  </div>
</section>

<style>
  /* Devpunks: chip FISSO (non nella pila) a fianco dei giornali dell'edicola. */
  .edicola-wrap{ display:flex; flex-wrap:wrap; align-items:flex-end; gap:12px 24px; }
  .edicola-devpunks{ flex:0 0 auto; margin-bottom:12px; }
</style>

<script>
  // Count-up per la statistica del numero, appena la tile entra in viewport.
  // Query distinta (.mag-stat) per non collidere con .big-stat di Field Notes.
  // Nuovo numero al mese = aggiungi la coppia it/ + en/ in src/content/magazine/.
  document.querySelectorAll<HTMLElement>('.mag-stat[data-target]').forEach((el) => {
    const target = parseInt(el.dataset.target || '0', 10);
    const suffix = el.dataset.suffix || '';

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = target + suffix;
      return;
    }

    let started = false;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !started) {
            started = true;
            const duration = 1100;
            const startTime = performance.now();
            function tick(now: number) {
              const progress = Math.min((now - startTime) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              el.textContent = Math.round(eased * target) + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
            io.unobserve(el);
          }
        });
      },
      { threshold: 0.5 }
    );
    io.observe(el);
  });
</script>

