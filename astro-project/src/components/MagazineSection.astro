---
import { numeroSezione } from '../lib/sections';
import { getCollection } from 'astro:content';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { magazineSlug } from '../lib/magazine';
import { defaultLang, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;

const issues = (await getCollection('magazine', (c) => c.data.lang === lang)).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

// Edicola: dove la firma di Marco esce anche fuori dal sito. Reso come una PILA
// da edicola (newsstand stack) — le firme impilate come giornali, sfalsate e
// ruotate. Solo link in uscita (nuova scheda). L'array qui sotto è la fonte:
// una firma a settimana = una riga in più, il layout regge da 2 a molti.
const DEVTO = 'https://dev.to/mk023/how-i-shipped-13-prs-in-one-afternoon-pair-programming-with-claude-and-what-i-learned-1274';
const DEVPUNKS = 'https://devpunks.com';

const copy = {
  it: {
    intro: "Ogni mese un caso vero di IA applicata sul lavoro: il problema, la scelta fatta, cosa è cambiato. Lo scrive una pipeline, controllato sulle fonti. Il primo è il punto zero: le idee migliorano strada facendo.",
    toggle: 'LEGGI',
    problem: 'PROBLEMA', approach: 'APPROCCIO', result: 'RISULTATO', lesson: 'LEZIONE APPRESA',
    permalink: 'Apri la pagina →',
    edicolaHead: 'Edicola · dove la firma esce anche fuori',
    devto: '13 PR con Claude in un pomeriggio',
    devpunks: 'Nel talent network',
    newTab: 'si apre in una nuova scheda',
  },
  en: {
    intro: 'One real case a month of AI put to work: the problem, the call made, what changed. A pipeline writes it, checked against the sources. The first one is point zero: ideas get better as you go.',
    toggle: 'READ',
    problem: 'PROBLEM', approach: 'APPROACH', result: 'RESULT', lesson: 'LESSON LEARNED',
    permalink: 'Open the page →',
    edicolaHead: 'Edicola · where the byline also runs',
    devto: 'Shipping 13 PRs in one afternoon',
    devpunks: 'In the talent network',
    newTab: 'opens in a new tab',
  },
}[lang];

// La pila è data-driven: aggiungere una firma = aggiungere un oggetto qui.
// Il layout regge da 2 a molti (nuova firma ~1/settimana). L'etichetta riusa
// le stringhe di copy per restare bilingue; sub e href sono neutri di lingua.
const bylines = [
  { label: copy.devto, sub: 'dev.to · 2026', href: DEVTO },
  { label: copy.devpunks, sub: 'Devpunks', href: DEVPUNKS },
];
---

<section id="magazine" class="reveal">
  <div class="section-head">
    <span class="num mono">{numeroSezione('magazine')}</span>
    <h2 class="display">Magazine</h2>
  </div>
  <p class="case-archive-note">{copy.intro}</p>
  <div class="mag-list">
    {issues.map((issue, i) => (
      <details class="mag-item">
        <summary class="mag-summary">
          <div class="mag-stat-col">
            {issue.data.stat != null ? (
              <div
                class="mag-stat display"
                id={`mag-stat-${i}`}
                data-target={issue.data.stat}
                data-suffix={issue.data.statSuffix ?? ''}
              >
                0{issue.data.statSuffix ?? ''}
              </div>
            ) : (
              <div class="mag-number display">N.{String(issue.data.number).padStart(2, '0')}</div>
            )}
            <span class="mag-cred mono">{issue.data.month.toUpperCase()} · {issue.data.sector}</span>
          </div>
          <div class="mag-summary-main">
            <h3 class="mag-title">{issue.data.title}</h3>
            <span class="mag-toggle mono">{copy.toggle}</span>
          </div>
        </summary>
        <div class="mag-body">
          <div class="case-block"><span class="label mono">{copy.problem}</span><p>{issue.data.problem}</p></div>
          <div class="case-block"><span class="label mono">{copy.approach}</span><p>{issue.data.approach}</p></div>
          <div class="case-block"><span class="label mono">{copy.result}</span><p>{issue.data.result}</p></div>
          <div class="case-block"><span class="label mono">{copy.lesson}</span><p>{issue.data.lesson}</p></div>
          <a class="mag-permalink mono" href={getRelativeLocaleUrl(lang, `magazine/${magazineSlug(issue)}`)}>{copy.permalink}</a>
        </div>
      </details>
    ))}
  </div>

  <div class="newsstand">
    <p class="certs-head mono">{copy.edicolaHead}</p>
    {/* Pila da edicola. Stato base (senza JS): riga leggibile e a capo, ogni
        link raggiungibile — è il fallback accessibile. Lo <script> aggiunge
        .is-enhanced e la collassa in pila; si apre a ventaglio su hover,
        :focus-within (tastiera) e tap (mobile, gestito nello script). */}
    <div class="newsstand-stack" data-newsstand>
      {bylines.map((b) => (
        <a
          class="paper"
          href={b.href}
          target="_blank"
          rel="noopener"
          aria-label={`${b.label} — ${b.sub} (${copy.newTab})`}
        >
          <span class="paper-source mono">{b.sub}</span>
          <span class="paper-title">{b.label}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  // Count-up per la statistica del numero, appena la tile entra in viewport.
  // Query distinta (.mag-stat) per non collidere con .big-stat di Field Notes.
  // Nuovo numero al mese = aggiungi la coppia it/ + en/ in src/content/magazine/.
  document.querySelectorAll<HTMLElement>('.mag-stat[data-target]').forEach((el) => {
    const target = parseInt(el.dataset.target || '0', 10);
    const suffix = el.dataset.suffix || '';

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      el.textContent = target + suffix;
      return;
    }

    let started = false;
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !started) {
            started = true;
            const duration = 1100;
            const startTime = performance.now();
            function tick(now: number) {
              const progress = Math.min((now - startTime) / duration, 1);
              const eased = 1 - Math.pow(1 - progress, 3);
              el.textContent = Math.round(eased * target) + suffix;
              if (progress < 1) requestAnimationFrame(tick);
            }
            requestAnimationFrame(tick);
            io.unobserve(el);
          }
        });
      },
      { threshold: 0.5 }
    );
    io.observe(el);
  });
</script>

<style>
  /* NEWSSTAND STACK — le firme esterne impilate come giornali in edicola.
     Stile scoped: Astro ne calcola l'hash nella CSP (style-src resta a hash,
     niente style="" inline). Tutto su var(--ink/--paper) → giorno e notte. */
  .newsstand{ margin-top:34px; }

  /* Contenitore. Il padding tiene i fogli ruotati lontani dai bordi così la
     rotazione non taglia nulla e non si sovrappone alla sezione dopo. */
  .newsstand-stack{
    display:flex;
    flex-wrap:wrap;
    align-items:flex-start;
    gap:14px;
    padding:6px 4px 10px;
  }

  /* Il singolo "giornale": bordo netto, ombra dura neo-brutalista. */
  .paper{
    position:relative;
    display:flex;
    flex-direction:column;
    gap:6px;
    flex:0 0 auto;
    width:min(240px, 78vw);
    padding:11px 14px 13px;
    text-decoration:none;
    color:var(--ink);
    background:var(--paper);
    border:2px solid var(--ink);
    box-shadow:4px 4px 0 var(--ink);
    transition:margin 0.28s cubic-bezier(.2,.7,.2,1),
               transform 0.28s cubic-bezier(.2,.7,.2,1),
               box-shadow 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  /* Masthead del giornale: la fonte come testata, con la sua riga sotto. */
  .paper-source{
    font-family:'JetBrains Mono', monospace;
    font-size:10px; letter-spacing:0.12em; text-transform:uppercase;
    opacity:0.62;
    padding-bottom:5px;
    border-bottom:1.5px solid var(--ink);
  }
  .paper-title{
    font-family:'Source Serif 4', serif;
    font-size:16px; font-weight:600; line-height:1.25;
  }
  .paper:hover, .paper:focus-visible{
    background:var(--ink); color:var(--paper);
    box-shadow:6px 6px 0 var(--orange);
  }
  .paper:hover .paper-source, .paper:focus-visible .paper-source{
    opacity:0.85; border-bottom-color:var(--paper);
  }
  /* Focus da tastiera sempre visibile, anche col foglio in cima alla pila. */
  .paper:focus-visible{
    outline:3px solid var(--orange);
    outline-offset:3px;
  }

  /* --- STATO POTENZIATO (JS presente): la riga collassa in PILA ---
     I fogli si sovrappongono con margini negativi e ruotano su un ciclo
     nth-child (nessuno style="" inline: il pattern vive qui). */
  .newsstand-stack.is-enhanced .paper:not(:first-child){ margin-left:-52%; }
  .newsstand-stack.is-enhanced .paper:nth-child(4n+1){ transform:rotate(-3.5deg) translateY(3px); }
  .newsstand-stack.is-enhanced .paper:nth-child(4n+2){ transform:rotate(2.5deg)  translateY(-2px); }
  .newsstand-stack.is-enhanced .paper:nth-child(4n+3){ transform:rotate(-1.5deg) translateY(1px); }
  .newsstand-stack.is-enhanced .paper:nth-child(4n+4){ transform:rotate(3deg)    translateY(-3px); }
  /* Il foglio in cima alla pila (l'ultimo nel flusso) è pienamente cliccabile;
     gli altri fanno capolino a sinistra. Il ventaglio li rende tutti raggiungibili. */

  /* --- VENTAGLIO: hover, focus da tastiera, o aperto al tap (.is-open) ---
     Si torna alla riga a capo: margini a zero, rotazione annullata. */
  .newsstand-stack.is-enhanced:hover .paper,
  .newsstand-stack.is-enhanced:focus-within .paper,
  .newsstand-stack.is-enhanced.is-open .paper{
    margin-left:0;
    transform:rotate(0);
  }

  /* Chi ha chiesto meno movimento: niente rotazioni né transizioni, resta la
     riga leggibile. La pila è una delizia, non un requisito. */
  @media (prefers-reduced-motion: reduce){
    .paper{ transition:box-shadow 0.15s ease, background 0.15s ease, color 0.15s ease; }
    .newsstand-stack.is-enhanced .paper{ margin-left:0; transform:none; }
  }
</style>

<script>
  // Progressive enhancement della pila da edicola. Senza questo script lo stato
  // base è una riga a capo con ogni link raggiungibile (fallback accessibile).
  // Qui la collassiamo in pila e gestiamo l'apertura al tap su mobile.
  const stack = document.querySelector<HTMLElement>('[data-newsstand]');
  if (stack) {
    stack.classList.add('is-enhanced');

    // Il tipo di puntatore dell'ultima interazione decide se intercettare il tap.
    // Tastiera/mouse non vengono intercettati: ci pensano :focus-within e :hover.
    let lastPointerType = '';
    stack.addEventListener('pointerdown', (e) => { lastPointerType = e.pointerType; }, true);
    stack.addEventListener('keydown', () => { lastPointerType = 'key'; }, true);

    // Su touch il PRIMO tap apre il ventaglio invece di seguire il link: così i
    // fogli sotto la pila diventano raggiungibili. Il secondo tap naviga.
    stack.addEventListener('click', (e) => {
      if (stack.classList.contains('is-open')) return;
      if (lastPointerType !== 'touch' && lastPointerType !== 'pen') return;
      const target = e.target as HTMLElement;
      if (!target.closest('a')) return;
      e.preventDefault();
      stack.classList.add('is-open');
    });

    // Un tap fuori richiude la pila.
    document.addEventListener('click', (e) => {
      if (!stack.contains(e.target as Node)) stack.classList.remove('is-open');
    });
  }
</script>
