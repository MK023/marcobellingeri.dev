---
// Pila da edicola riusabile: le voci impilate come giornali, sfalsate e ruotate,
// che si aprono a ventaglio su hover / focus da tastiera / tap (mobile). Usata sia
// dall'Edicola (firme esterne) sia dalle Certificazioni. Data-driven: una voce =
// un oggetto in `items`. Solo link in uscita (nuova scheda).
interface Item { label: string; sub: string; href: string; }
interface Props { head: string; items: Item[]; newTab: string; }
const { head, items, newTab } = Astro.props;
---

<div class="newsstand">
  <p class="certs-head mono">{head}</p>
  {/* Stato base (senza JS): riga a capo, ogni link raggiungibile — fallback
      accessibile. Lo <script> aggiunge .is-enhanced e la collassa in pila. */}
  <div class="newsstand-stack" data-newsstand>
    {items.map((b) => (
      <a
        class="paper"
        href={b.href}
        target="_blank"
        rel="noopener"
        aria-label={`${b.label} — ${b.sub} (${newTab})`}
      >
        <span class="paper-source mono">{b.sub}</span>
        <span class="paper-title">{b.label}</span>
      </a>
    ))}
  </div>
</div>

<script>
  // Progressive enhancement. querySelectorAll (non querySelector): la pila può
  // comparire più volte nella pagina (Edicola + Certificazioni) e lo <script> del
  // componente gira una volta sola — deve potenziarle tutte.
  // Riserva solo dove il ventaglio si apre in hover E il layout misurabile è
  // quello giusto: sotto i 761px la pila è verticale (media query sotto) e lo
  // stato pre-enhance NON è più l'aperto — lì lo spostamento resta, com'è già
  // accettato sul touch (l'apertura è un tap voluto).
  const hoverFine = window.matchMedia('(hover:hover) and (pointer:fine) and (min-width:761px)');
  document.querySelectorAll<HTMLElement>('[data-newsstand]').forEach((stack) => {
    // Riserva l'altezza del ventaglio APERTO prima di collassare: lo stato senza
    // .is-enhanced è già il layout aperto (wrap), quindi basta misurarlo. Così
    // l'hover non sposta la sezione sotto. Su touch riservare le righe vuote
    // costerebbe schermate bianche. Tutto sincrono nello stesso frame: niente flash.
    const riserva = () => {
      stack.classList.add('no-anim');
      if (hoverFine.matches) {
        stack.classList.remove('is-enhanced');
        stack.style.minHeight = '';
        stack.style.minHeight = `${stack.offsetHeight}px`;
      } else {
        // niente misura (e niente doppio reflow) dove non serve: su mobile il
        // resize scatta a ogni comparsa della barra URL durante lo scroll.
        stack.style.minHeight = '';
      }
      stack.classList.add('is-enhanced');
      void stack.offsetHeight; // reflow: separa il collasso dalla riattivazione delle transizioni
      stack.classList.remove('no-anim');
    };
    riserva();
    let raf = 0;
    const rimisura = () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(riserva);
    };
    window.addEventListener('resize', rimisura);
    // La prima misura può avvenire coi font di fallback: al swap le altezze
    // cambiano. E il mouse può comparire dopo (iPad + trackpad).
    document.fonts?.ready.then(rimisura);
    hoverFine.addEventListener?.('change', rimisura);

    // Ventaglio da tastiera: si apre solo col focus VISIBILE (:focus-visible),
    // riusando .is-open. Niente :focus-within in CSS: dopo un click su un link
    // target=_blank il focus resta sul foglio e terrebbe la pila aperta per sempre.
    stack.addEventListener('focusin', (e) => {
      const t = e.target as HTMLElement;
      try {
        if (t.matches(':focus-visible')) stack.classList.add('is-open');
      } catch {
        // Safari < 15.4 (niente :focus-visible): meglio il vecchio comportamento
        // "apri su qualsiasi focus" che una tastiera senza ventaglio.
        stack.classList.add('is-open');
      }
    });
    stack.addEventListener('focusout', (e) => {
      if (!stack.contains(e.relatedTarget as Node)) stack.classList.remove('is-open');
    });

    // Il tipo di puntatore dell'ultima interazione decide se intercettare il tap.
    // Tastiera/mouse non vengono intercettati: ci pensano .is-open e :hover.
    let lastPointerType = '';
    stack.addEventListener('pointerdown', (e) => { lastPointerType = (e as PointerEvent).pointerType; }, true);
    stack.addEventListener('keydown', () => { lastPointerType = 'key'; }, true);

    // Su touch il PRIMO tap apre il ventaglio invece di seguire il link: i fogli
    // sotto diventano raggiungibili. Il secondo tap naviga. Un tap fuori richiude.
    stack.addEventListener('click', (e) => {
      if (stack.classList.contains('is-open')) return;
      if (lastPointerType !== 'touch' && lastPointerType !== 'pen') return;
      if (!(e.target as HTMLElement).closest('a')) return;
      e.preventDefault();
      stack.classList.add('is-open');
    });
    document.addEventListener('click', (e) => {
      if (!stack.contains(e.target as Node)) stack.classList.remove('is-open');
    });
  });
</script>

<style>
  /* Scoped: Astro ne hasha lo stile nella CSP (niente style="" inline). Tutto su
     var(--ink/--paper) → giorno e notte. */
  .newsstand{ margin-top:34px; }

  .newsstand-stack{
    display:flex; flex-wrap:wrap; align-items:flex-start;
    gap:14px; padding:6px 4px 12px;
  }

  .paper{
    position:relative; display:flex; flex-direction:column; gap:6px;
    flex:0 0 auto; width:min(240px, 78vw);
    padding:11px 14px 13px;
    text-decoration:none; color:var(--ink); background:var(--paper);
    border:2px solid var(--ink); box-shadow:4px 4px 0 var(--ink);
    /* Più lento e con easing ease-out morbido: l'apertura respira invece di
       scattare. margin/transform separati dal resto (colore/ombra restano rapidi). */
    transition:margin 0.45s cubic-bezier(.22,.61,.36,1),
               transform 0.45s cubic-bezier(.22,.61,.36,1),
               box-shadow 0.15s ease, background 0.15s ease, color 0.15s ease;
  }
  .paper-source{
    font-family:'JetBrains Mono', monospace;
    font-size:10px; letter-spacing:0.12em; text-transform:uppercase;
    opacity:0.62; padding-bottom:5px; border-bottom:1.5px solid var(--ink);
  }
  .paper-title{
    font-family:'Source Serif 4', serif;
    font-size:16px; font-weight:600; line-height:1.25;
  }
  /* :hover e :focus-visible in regole SEPARATE: un browser senza :focus-visible
     (Safari ≤ 15.3) butta l'intera lista di selettori, e con la virgola
     perderebbe anche l'hover. */
  .paper:hover{
    background:var(--ink); color:var(--paper);
    box-shadow:6px 6px 0 var(--orange);
  }
  .paper:focus-visible{
    background:var(--ink); color:var(--paper);
    box-shadow:6px 6px 0 var(--orange);
  }
  .paper:hover .paper-source{ opacity:0.85; border-bottom-color:var(--paper); }
  .paper:focus-visible .paper-source{ opacity:0.85; border-bottom-color:var(--paper); }
  .paper:focus-visible{ outline:3px solid var(--orange); outline-offset:3px; }

  /* Pila (JS presente): riga singola che si sovrappone marciando verso destra.
     Overlap FISSO in px (non %: la % è relativa al contenitore e con molte voci
     spinge i fogli fuori dallo schermo a sinistra). Ogni foglio mostra ~65px. */
  /* fit-content: la zona che apre in hover è la pila, non tutta la riga vuota
     a destra. Da aperto (wrap) fit-content torna a valere la larghezza piena. */
  .newsstand-stack.is-enhanced{ flex-wrap:nowrap; width:fit-content; }
  .newsstand-stack.is-enhanced .paper:not(:first-child){ margin-left:-176px; }
  .newsstand-stack.is-enhanced .paper:nth-child(4n+1){ transform:rotate(-2.2deg) translateY(2px); }
  .newsstand-stack.is-enhanced .paper:nth-child(4n+2){ transform:rotate(1.6deg)  translateY(-1px); }
  .newsstand-stack.is-enhanced .paper:nth-child(4n+3){ transform:rotate(-1deg)   translateY(1px); }
  .newsstand-stack.is-enhanced .paper:nth-child(4n+4){ transform:rotate(2deg)    translateY(-2px); }

  /* Durante la misura dell'altezza riservata (script) le transizioni sono spente:
     il collasso iniziale e le ri-misure su resize scattano senza animare. */
  .newsstand-stack.no-anim .paper{ transition:none; }

  /* Ventaglio: si torna alla riga. L'apertura è a CASCATA (transition-delay sui
     figli successivi) così i fogli si aprono uno dopo l'altro, non tutti insieme:
     è quello che la fa sembrare naturale. In chiusura il delay non c'è → richiude
     svelta. */
  /* Ventaglio: la riga torna a capo (wrap) così tutti i fogli sono raggiungibili
     anche quando la pila era più larga dello schermo. Niente :focus-within: il
     focus da click (link target=_blank) terrebbe la pila aperta anche a cursore
     lontano — il focus da tastiera passa da .is-open, messo dallo script solo
     su :focus-visible. */
  .newsstand-stack.is-enhanced:hover,
  .newsstand-stack.is-enhanced.is-open{ flex-wrap:wrap; }
  .newsstand-stack.is-enhanced:hover .paper,
  .newsstand-stack.is-enhanced.is-open .paper{ margin-left:0; transform:rotate(0); }

  .newsstand-stack.is-enhanced:hover .paper:nth-child(2),
  .newsstand-stack.is-enhanced.is-open .paper:nth-child(2){ transition-delay:0.04s; }
  .newsstand-stack.is-enhanced:hover .paper:nth-child(3),
  .newsstand-stack.is-enhanced.is-open .paper:nth-child(3){ transition-delay:0.08s; }
  .newsstand-stack.is-enhanced:hover .paper:nth-child(4),
  .newsstand-stack.is-enhanced.is-open .paper:nth-child(4){ transition-delay:0.12s; }
  .newsstand-stack.is-enhanced:hover .paper:nth-child(5),
  .newsstand-stack.is-enhanced.is-open .paper:nth-child(5){ transition-delay:0.16s; }
  .newsstand-stack.is-enhanced:hover .paper:nth-child(n+6),
  .newsstand-stack.is-enhanced.is-open .paper:nth-child(n+6){ transition-delay:0.2s; }

  /* Sotto i 760px la pila orizzontale non ci sta (8 fogli sfalsati ≈ 790px:
     sbordavano e l'iPhone zoomava fuori l'intera pagina). Si impila in VERTICALE
     come giornali visti di fronte: resta il taglio da edicola, resta il tap per
     aprire. ponytail: oltre ~9 voci anche la riga desktop a 760-800px va stretta —
     se la pila cresce, rivedere l'overlap. */
  @media (max-width:760px){
    .newsstand-stack.is-enhanced{ flex-direction:column; flex-wrap:nowrap; }
    .newsstand-stack.is-enhanced .paper:not(:first-child){ margin-left:0; margin-top:-58px; }
    .newsstand-stack.is-enhanced:hover .paper,
    .newsstand-stack.is-enhanced.is-open .paper{ margin-top:0; }
  }

  /* Reduced motion: niente pila né rotazioni, resta la riga leggibile. */
  @media (prefers-reduced-motion: reduce){
    .paper{ transition:box-shadow 0.15s ease, background 0.15s ease, color 0.15s ease; }
    .newsstand-stack.is-enhanced .paper,
    .newsstand-stack.is-enhanced .paper:not(:first-child){ margin:0; transform:none; }
  }
</style>
