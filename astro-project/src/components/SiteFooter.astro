---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, defaultLang, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);
const privacyUrl = getRelativeLocaleUrl(lang, 'privacy');
const aiUrl = getRelativeLocaleUrl(lang, 'ai');

const EMAIL = 'mkdevpy@proton.me';
// Verifica-socio live: mostra da sé la validità aggiornata, così la scadenza non
// viene mai duplicata (e quindi non mente) nell'HTML statico.
const AIPIA_VERIFY = 'https://aipia.it/attivita-e-progetti/verifica-socio/?token=14b392b';

const links = [
  'https://github.com/MK023',
  'https://linkedin.com/in/marco-bellingeri',
  'https://credly.com/users/marco-bellingeri',
  'https://linktr.ee/MK023',
];
---

<footer id="contact" class="reveal">
  <div class="colophon">
    <div>
      <h3>{t('foot.contacts')}</h3>
      <a href={`mailto:${EMAIL}`}>{EMAIL}</a>
      <button
        class="util-btn"
        id="copy-email-btn"
        data-email={EMAIL}
        data-label={t('foot.copy')}
        data-copied={t('foot.copied')}
        data-error={t('foot.copyError')}
      >{t('foot.copy')}</button><br />
      Casale Monferrato, Alessandria, IT
    </div>
    <div>
      <h3>{t('foot.online')}</h3>
      {links.map((href) => (
        <><a href={href} target="_blank" rel="noopener">{href.replace('https://', '')}</a><br /></>
      ))}
    </div>
    <div>
      <h3>{t('foot.colophon')}</h3>
      {t('foot.setIn')}<br />
      {t('foot.printed')}
      <div class="colophon-marks">
        <div class="ai-seal" title={t('foot.sealTitle')}>
        <div class="ai-seal-ring">
          <svg viewBox="0 0 100 100">
            <path id="badgeCirclePath" d="M 50,50 m -38,0 a 38,38 0 1,1 76,0 a 38,38 0 1,1 -76,0" fill="none"></path>
            <text class="ring-text">
              <textPath href="#badgeCirclePath" startOffset="0%">
                COSTRUITO CON CLAUDE CODE • PAIR PROGRAMMING, NON PROMPT-E-VAI •
              </textPath>
            </text>
          </svg>
        </div>
        <div class="ai-seal-core">✳</div>
        </div>
        <a class="aipia-mark" href={AIPIA_VERIFY} target="_blank" rel="noopener" aria-label={t('foot.aipia')} title={t('foot.aipia')}>
          <img src="/aipia-socio.png" alt="" width="84" height="84" loading="lazy" decoding="async" />
        </a>
      </div>
    </div>
  </div>
  <p class="fine-print">{t('foot.finePrint')} · <a href={privacyUrl}>Privacy</a> · <a href={aiUrl}>{lang === 'it' ? 'Trasparenza AI' : 'AI transparency'}</a></p>
</footer>

<script>
  // ---- copy email ----
  const copyBtn = document.getElementById('copy-email-btn');
  if (copyBtn) {
    copyBtn.addEventListener('click', async () => {
      const { email = '', label = '', copied = '', error = '' } = (copyBtn as HTMLElement).dataset;
      try {
        await navigator.clipboard.writeText(email);
        copyBtn.textContent = copied;
        copyBtn.classList.add('copied');
        setTimeout(() => {
          copyBtn.textContent = label;
          copyBtn.classList.remove('copied');
        }, 1800);
      } catch {
        copyBtn.textContent = error;
      }
    });
  }
</script>
