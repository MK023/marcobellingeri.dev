---
// Scheduler staccato (era il Calendly personale). Qui andrà il tool di
// prenotazione professionale: per ricollegarlo, ripristina un embed/facade
// in questa sezione e riapri la CSP in public/_headers per quel dominio.
---

<section id="booking" class="reveal">
  <div class="section-head">
    <span class="num mono">07</span>
    <h2 class="display">Appuntamenti</h2>
  </div>
  <p class="booking-note">
    Slot liberi, fuso orario gestito in automatico, conferma via email —
    niente scambi di messaggi per trovare un orario.
  </p>
  <div class="booking-frame">
    <div class="booking-placeholder">
      <p class="facade-label mono">SCHEDULER IN ARRIVO</p>
      <p class="facade-copy">
        Il calendario prenotazioni professionale sarà collegato qui a breve.
      </p>
    </div>
  </div>
</section>

<style>
  /* .booking-placeholder è in global.css; qui solo i figli specifici. */
  .facade-label{ font-size:11px; letter-spacing:0.12em; opacity:0.6; }
  .facade-copy{ max-width:46ch; font-size:14px; line-height:1.5; }
</style>
