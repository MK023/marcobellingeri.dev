---
import { numeroSezione } from '../lib/sections';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { useTranslations, defaultLang, type Lang } from '../i18n/ui';
import PortalButton from './PortalButton.astro';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

// Il portale verso il Radar: la sezione dimostra che QUESTO sito è sicuro,
// la pagina Radar estende lo stesso gesto al mondo — bollettini ufficiali,
// fonti linkate, licenze dichiarate.
const radar = {
  it: { label: 'Radar', sub: 'security world events — chi attacca, chi risponde, chi scrive le regole' },
  en: { label: 'Radar', sub: 'security world events — who attacks, who responds, who writes the rules' },
}[lang];

// Header attesi = quelli serviti da public/_headers. La card li rilegge LIVE
// dalla risposta della pagina stessa (auto-referenziale): il sito dimostra
// ciò che predica.
const expected = [
  'Content-Security-Policy',
  'Strict-Transport-Security',
  'X-Content-Type-Options',
  'Referrer-Policy',
  'Permissions-Policy',
];
---

<section id="security" class="reveal">
  <div class="section-head">
    <span class="num mono">{numeroSezione('security')}</span>
    <h2 class="display">{t('sec.title')}</h2>
  </div>
  <p class="case-archive-note">{t('sec.intro')}</p>
  <div class="live-stack">
    <div class="live-stack-head">
      <h3 class="mono">{t('sec.cmd')}</h3>
      <span class="src mono">{t('sec.source')}</span>
    </div>
    <div
      id="sec-headers"
      data-expected={expected.join(',')}
    >
      <p class="live-stack-status mono" id="sec-status">{t('sec.loading')}</p>
    </div>
    <p class="sec-note mono">{t('sec.note')}</p>
    <p class="sec-note mono">{t('sec.aiNote')}</p>
  </div>
  <PortalButton href={getRelativeLocaleUrl(lang, 'radar')} label={radar.label} sub={radar.sub} />
</section>

<script>
  // Legge live gli header di sicurezza dalla risposta della pagina (same-origin:
  // gli header sono leggibili). DOM costruito con textContent → nessun innerHTML.
  (function loadSecurityHeaders() {
    const box = document.getElementById('sec-headers');
    const status = document.getElementById('sec-status');
    if (!box) return;
    const expected = (box.dataset.expected || '').split(',').filter(Boolean);
    // Flag costanti, non traducibili (ON / —): inline, non nel dizionario i18n.
    const okLabel = 'ON';
    const missLabel = '—';

    const cell = (cls: string, text: string) => {
      const el = document.createElement('span');
      el.className = cls;
      el.textContent = text;
      return el;
    };

    const row = (name: string, val: string | null) => {
      const el = document.createElement('div');
      el.className = 'sec-row' + (val ? '' : ' is-missing');
      el.append(
        cell('sec-name', name),
        cell('sec-flag', val ? okLabel : missLabel),
        cell('sec-val', val || ''),
      );
      return el;
    };

    // La CSP effettiva ha due sorgenti: l'header (solo `frame-ancestors`, l'unica
    // direttiva che un <meta> non può esprimere) e il <meta http-equiv> generato
    // da Astro con gli hash dei suoi script. Mostrare solo l'header direbbe metà
    // della verità su una pagina che promette di non dirne mezze.
    // Gli hash sono decine: li conto invece di stamparli, ma il conteggio è letto
    // dal valore reale, non dichiarato qui.
    const metaCsp = document
      .querySelector<HTMLMetaElement>('meta[http-equiv="content-security-policy" i]')
      ?.content ?? null;

    const foldHashes = (csp: string) =>
      csp.replace(/(?:'sha\d{3}-[A-Za-z0-9+/=]+'\s*)+/g, (run) => {
        const n = run.match(/'sha\d{3}-/g)?.length ?? 0;
        return `${n} hash `;
      });

    fetch(window.location.href, { method: 'HEAD' })
      .then((res) => {
        box.replaceChildren();
        expected.forEach((name) => box.appendChild(row(name, res.headers.get(name))));
        box.appendChild(row('Content-Security-Policy (meta)', metaCsp && foldHashes(metaCsp)));

        // Le due righe AI. Il terminale stampa testo di un modello: che non
        // diventi codice non è una promessa, è una policy che il browser ha già
        // applicato quando leggi questa riga. Si guardano ENTRAMBE le sorgenti
        // (header + meta): se una delle due concedesse la deroga, vincerebbe la
        // deroga, e mostrare solo l'altra direbbe mezza verità.
        const cspEffettiva = [res.headers.get('Content-Security-Policy'), metaCsp]
          .filter(Boolean)
          .join(' ; ');
        const senza = (token: string) =>
          cspEffettiva && !cspEffettiva.includes(token) ? 'OWASP LLM02 · output handling' : null;
        box.appendChild(row("CSP: no 'unsafe-inline'", senza("'unsafe-inline'")));
        box.appendChild(row("CSP: no 'unsafe-eval'", senza("'unsafe-eval'")));
      })
      .catch(() => {
        if (status) status.textContent = missLabel;
      });
  })();
</script>
