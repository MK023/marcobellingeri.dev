---
import { useTranslations, defaultLang, type Lang } from '../i18n/ui';
import { sections } from '../lib/sections';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const entries = sections(t);
---

<nav class="toc mono" id="toc-nav">
  {entries.map((e) => (
    <a href={`#${e.id}`} data-section={e.id}><span class="num">{e.num}</span> {e.label}</a>
  ))}
</nav>
{/* La dissolvenza sopra la toc NON può essere un ::before della toc: overflow-x:auto
    la ritaglierebbe (un asse non-visible trascina anche l'altro). Vive da fratello,
    fixed sopra il bordo del viewport — la striscia dietro la status bar di Safari. */}
<div class="toc-fade" aria-hidden="true"></div>
<p class="toc-hint mono">{t('nav.hint')}</p>

<script>
  // ---- altezze reali delle due barre sticky → variabili CSS ----
  // La utility-bar ha flex-wrap: sotto i ~520px va a capo e passa da 60 a 83px.
  // Con un `top` fisso il sommario finiva mezzo nascosto dietro di lei, e le
  // ancore delle sezioni atterravano troppo in alto. Misura il browser, non io.
  (function stickyHeights() {
    const bar = document.querySelector<HTMLElement>('.utility-bar');
    const toc = document.querySelector<HTMLElement>('.toc');
    if (!bar || !toc) return;

    const apply = () => {
      const root = document.documentElement;
      root.style.setProperty('--bar-h', bar.offsetHeight + 'px');
      root.style.setProperty('--toc-h', toc.offsetHeight + 'px');
    };

    apply();
    // `typeof`, non `'ResizeObserver' in window`: la libreria DOM di TypeScript dà
    // ResizeObserver per garantito, quindi con `in` restringe l'else a `never` e il
    // fallback diventa codice morto ai suoi occhi. Qui siamo più prudenti di lei —
    // il fallback serve davvero, e va scritto in modo che TS lo veda vivo.
    if (typeof ResizeObserver !== 'undefined') {
      const ro = new ResizeObserver(apply);
      ro.observe(bar);
      ro.observe(toc);
    } else {
      window.addEventListener('resize', apply, { passive: true });
    }
  })();

  // ---- is-stuck: accende la dissolvenza sopra la toc solo quando è incollata ----
  // (global.css, media mobile). A riposo la dissolvenza coprirebbe l'hero.
  (function stuckFlag() {
    const toc = document.querySelector<HTMLElement>('.toc');
    if (!toc) return;
    let queued = false;
    function check() {
      if (queued) return;
      queued = true;
      requestAnimationFrame(() => {
        queued = false;
        toc!.classList.toggle('is-stuck', toc!.getBoundingClientRect().top <= 0);
      });
    }
    window.addEventListener('scroll', check, { passive: true });
    check();
  })();

  // ---- scroll-spy: evidenzia la sezione attiva nel sommario ----
  (function scrollSpy() {
    const links = Array.from(document.querySelectorAll<HTMLAnchorElement>('#toc-nav a'));
    if (!links.length) return;
    const sections = links
      .map((a) => document.getElementById(a.dataset.section || ''))
      .filter((el): el is HTMLElement => Boolean(el));

    // porta la voce indicata in vista dentro la striscia scorrevole, senza scrollare la pagina
    function revealInNav(link: HTMLAnchorElement) {
      const nav = document.getElementById('toc-nav');
      if (!nav) return;
      const linkLeft = link.offsetLeft;
      const linkRight = linkLeft + link.offsetWidth;
      if (linkLeft < nav.scrollLeft || linkRight > nav.scrollLeft + nav.clientWidth) {
        nav.scrollTo({ left: linkLeft - 20, behavior: 'smooth' });
      }
    }

    function activate(link: HTMLAnchorElement) {
      links.forEach((l) => l.classList.remove('active'));
      link.classList.add('active');
      revealInNav(link);
    }

    // L'ultima sezione (#contact) è il footer in fondo alla pagina: il suo bordo
    // superiore non entra mai nella fascia centrale del rootMargin, quindi
    // l'observer da solo non la attiva. `atBottom` fa fede quando si tocca il
    // fondo pagina e ha la precedenza sull'observer (vedi guardia sotto).
    let atBottom = false;
    const lastLink = links[links.length - 1];

    const spyIo = new IntersectionObserver(
      (entries) => {
        // A fondo pagina comanda lo scroll listener: ignora l'observer, altrimenti
        // ri-attiverebbe la penultima sezione subito dopo l'attivazione dell'ultima.
        if (atBottom) return;
        entries.forEach((entry) => {
          const link = document.querySelector<HTMLAnchorElement>(
            '#toc-nav a[data-section="' + entry.target.id + '"]'
          );
          if (!link) return;
          if (entry.isIntersecting) activate(link);
        });
      },
      { rootMargin: '-45% 0px -50% 0px', threshold: 0 }
    );

    sections.forEach((s) => spyIo.observe(s));

    // Rileva il fondo pagina e forza l'ultima voce attiva. N piccolo (3px) tollera
    // arrotondamenti sub-pixel e zoom. Il lavoro di layout si fa una volta per frame.
    let queued = false;
    function onScroll() {
      if (queued) return;
      queued = true;
      requestAnimationFrame(() => {
        queued = false;
        // Su una pagina non scorrevole (zoom estremo, viewport altissimo) si è
        // sempre "a fondo pagina": senza questa guardia `atBottom` resterebbe
        // bloccato e spegnerebbe l'observer per tutte le altre sezioni.
        const scrollabile = document.documentElement.scrollHeight > window.innerHeight + 4;
        const nowBottom =
          scrollabile &&
          window.innerHeight + window.scrollY >= document.documentElement.scrollHeight - 3;
        if (nowBottom) {
          atBottom = true;
          if (lastLink && !lastLink.classList.contains('active')) activate(lastLink);
        } else if (atBottom) {
          // Staccandosi dal fondo si ridà la parola all'observer: al prossimo
          // aggiornamento riattiverà la sezione che attraversa la fascia centrale.
          atBottom = false;
        }
      });
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    onScroll();
  })();
</script>
