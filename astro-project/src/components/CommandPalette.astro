---
import { useTranslations, defaultLang, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

// Le voci "vai a" riusano le etichette del sommario: una sola fonte per i nomi
// delle sezioni.
const sections = [
  ['dossier', '01', t('nav.dossier')],
  ['servizi', '02', t('nav.servizi')],
  ['field-notes', '03', t('nav.fieldNotes')],
  ['projects', '04', t('nav.projects')],
  ['percorso', '05', t('nav.percorso')],
  ['stack', '06', t('nav.stack')],
  ['security', '07', t('nav.security')],
  ['archive', '08', t('nav.archive')],
  ['booking', '09', t('nav.booking')],
  ['contact', '10', t('nav.contact')],
];

const strings = {
  goTo: t('cmdk.goTo'),
  openGithub: t('cmdk.openGithub'),
  copyEmail: t('cmdk.copyEmail'),
  printCv: t('cmdk.printCv'),
  openTerminal: t('cmdk.openTerminal'),
  empty: t('cmdk.empty'),
  commands: t('ub.commands'),
  commandsTitle: t('ub.commandsTitle'),
};
---

<div
  class="cmdk-overlay"
  id="cmdk-overlay"
  data-sections={JSON.stringify(sections)}
  data-strings={JSON.stringify(strings)}
>
  <div class="cmdk-box">
    <input
      class="cmdk-input mono"
      id="cmdk-input"
      type="text"
      placeholder={t('cmdk.placeholder')}
      autocomplete="off"
      role="combobox"
      aria-expanded="true"
      aria-controls="cmdk-list"
      aria-label={t('cmdk.placeholder')}
    />
    <div class="cmdk-list mono" id="cmdk-list" role="listbox"></div>
    <div class="cmdk-hint">
      <span>{t('cmdk.navHint')}</span>
      <span>{t('cmdk.escHint')}</span>
    </div>
  </div>
</div>

<script>
  declare global {
    interface Window { openNeonTerminal?: () => void; }
  }

  type Command = { label: string; hint: string; action: () => void };

  (function commandPalette() {
    const overlay = document.getElementById('cmdk-overlay');
    const input = document.getElementById('cmdk-input') as HTMLInputElement | null;
    const list = document.getElementById('cmdk-list');
    const trigger = document.getElementById('cmdk-trigger');
    if (!overlay || !input || !list || !trigger) return;

    const sections: [string, string, string][] = JSON.parse(overlay.dataset.sections || '[]');
    const S = JSON.parse(overlay.dataset.strings || '{}');

    function scrollToId(id: string) {
      document.getElementById(id)?.scrollIntoView({ behavior: 'smooth' });
      close();
    }

    const commands: Command[] = [
      ...sections.map(([id, num, label]) => ({
        label: `${S.goTo} — ${label}`,
        hint: num,
        action: () => scrollToId(id),
      })),
      { label: `${S.openGithub} — MK023`, hint: '↗', action: () => window.open('https://github.com/MK023', '_blank', 'noopener') },
      { label: S.copyEmail, hint: '⧉', action: () => (document.getElementById('copy-email-btn') as HTMLButtonElement | null)?.click() },
      { label: S.printCv, hint: '⎙', action: () => window.print() },
      { label: S.openTerminal, hint: '⌨', action: () => window.openNeonTerminal && window.openNeonTerminal() },
    ];

    // Su Mac la scorciatoia è ⌘K, altrove Ctrl+K: l'etichetta deve dire il vero.
    const isMac = (() => {
      try {
        const uaPlatform = (navigator as any).userAgentData?.platform;
        if (uaPlatform) return /mac/i.test(uaPlatform);
        return /mac|iphone|ipad|ipod/i.test(navigator.platform || navigator.userAgent);
      } catch (e) { return false; }
    })();
    trigger.textContent = (isMac ? '⌘K ' : 'CTRL K ') + S.commands;
    trigger.setAttribute('title', (isMac ? '⌘K' : 'Ctrl+K') + S.commandsTitle);

    let filtered = commands;
    let activeIndex = 0;

    function render() {
      if (!list) return;
      list.replaceChildren();
      if (filtered.length === 0) {
        const empty = document.createElement('div');
        empty.className = 'cmdk-empty';
        empty.textContent = S.empty;
        list.appendChild(empty);
        return;
      }
      let activeEl: HTMLElement | null = null;
      filtered.forEach((cmd, i) => {
        const item = document.createElement('div');
        item.className = 'cmdk-item' + (i === activeIndex ? ' active' : '');
        item.setAttribute('role', 'option');
        item.setAttribute('aria-selected', i === activeIndex ? 'true' : 'false');

        const label = document.createElement('span');
        label.textContent = cmd.label;
        const hint = document.createElement('span');
        hint.className = 'k';
        hint.textContent = cmd.hint;

        item.append(label, hint);
        item.addEventListener('mouseenter', () => { activeIndex = i; render(); });
        item.addEventListener('click', () => cmd.action());
        list!.appendChild(item);
        if (i === activeIndex) activeEl = item;
      });

      // tiene la voce selezionata dentro la finestra scorrevole della lista
      if (activeEl) {
        const listRect = list.getBoundingClientRect();
        const itemRect = (activeEl as HTMLElement).getBoundingClientRect();
        if (itemRect.top < listRect.top) list.scrollTop -= listRect.top - itemRect.top;
        else if (itemRect.bottom > listRect.bottom) list.scrollTop += itemRect.bottom - listRect.bottom;
      }
    }

    function open() {
      overlay!.classList.add('open');
      input!.value = '';
      filtered = commands;
      activeIndex = 0;
      render();
      setTimeout(() => input!.focus(), 30);
    }
    function close() {
      overlay!.classList.remove('open');
    }

    trigger.addEventListener('click', open);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

    input.addEventListener('input', () => {
      const q = input.value.toLowerCase();
      filtered = commands.filter((c) => c.label.toLowerCase().includes(q));
      activeIndex = 0;
      render();
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') { e.preventDefault(); activeIndex = Math.min(activeIndex + 1, filtered.length - 1); render(); }
      if (e.key === 'ArrowUp') { e.preventDefault(); activeIndex = Math.max(activeIndex - 1, 0); render(); }
      if (e.key === 'Enter') { e.preventDefault(); if (filtered[activeIndex]) filtered[activeIndex].action(); }
      if (e.key === 'Escape') { close(); }
    });

    document.addEventListener('keydown', (e) => {
      if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
        e.preventDefault();
        overlay!.classList.contains('open') ? close() : open();
      }
      if (e.key === 'Escape' && overlay!.classList.contains('open')) close();
    });
  })();
</script>
