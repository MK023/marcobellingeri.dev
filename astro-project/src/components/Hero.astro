---
import { defaultLang, useTranslations, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

// Voto della HTTP Observatory di Mozilla, misurato il 2026-07-10 sul sito servito:
// A+, punteggio 130, 10 test su 10. Non è una dichiarazione nostra e non deve
// diventarlo: la chip linka la scansione, che chiunque può rifare in quel momento.
// Se il voto scende, il link lo dice — e questa costante va aggiornata a mano,
// perché un voto che si aggiorna da solo non è un voto, è un adesivo.
const OBSERVATORY = {
  voto: 'A+',
  url: 'https://developer.mozilla.org/en-US/observatory/analyze?host=marcobellingeri.dev',
};

// Chiusura di «Computing Machinery and Intelligence» (Mind, 1950, p. 460).
// Citazione verificata alla fonte: non parafrasarla.
const copy = {
  it: {
    // Prima della citazione: cosa risolvo e per chi. Un visitatore freddo non
    // sa chi sono, quindi la testata da sola non basta a trattenerlo.
    pitch:
      "Rendo affidabile e sicura l'infrastruttura cloud di team che hanno già un sistema in produzione e non possono permettersi di fermarlo — agenti AI inclusi.",
    cta: 'PRENOTA 30 MINUTI — GRATIS, NESSUN IMPEGNO',
    quote: '«Riusciamo a vedere solo poco lontano, ma quanto basta per scorgere tutto ciò che resta da fare.»',
    source: 'Computing Machinery and Intelligence, 1950',
  },
  en: {
    pitch:
      'I make cloud infrastructure reliable and secure for teams that already run a system in production and cannot afford to stop it — AI agents included.',
    cta: 'BOOK 30 MINUTES — FREE, NO COMMITMENT',
    quote: '“We can only see a short distance ahead, but we can see plenty there that needs to be done.”',
    source: 'Computing Machinery and Intelligence, 1950',
  },
}[lang];
---

<header class="hero">
  <div class="halftone-frame" aria-hidden="true"></div>
  <div class="masthead-wrap">
    <span class="issue-tag mono">CLOUD &amp; SECURITY EDITION</span>
    <h1 class="name display"><span class="given">Marco</span>Bellingeri</h1>
    <div class="chips-row">
      <span class="role-chip mono">CLOUD PLATFORM &amp; AI SECURITY ENGINEER</span>
      <a
        class="grade-chip mono"
        href={OBSERVATORY.url}
        target="_blank"
        rel="noopener"
        title={t('hero.gradeTitle')}
      >
        <span class="grade-label">{t('hero.grade')}</span>
        <span class="grade-value">{OBSERVATORY.voto}</span>
        <span class="grade-verify">{t('hero.gradeVerify')} ↗</span>
      </a>
    </div>
    <p class="pitch">{copy.pitch}</p>
    <a class="hero-cta mono" href="#booking">{copy.cta}</a>
    <figure class="kicker">
      <blockquote>{copy.quote}</blockquote>
      <figcaption class="mono">Alan Turing — <cite>{copy.source}</cite></figcaption>
    </figure>
  </div>
</header>

<style>
  /* Il nome di battesimo fa da sopratitolo alla testata, un terzo del cognome. */
  h1.name .given{
    display:block;
    font-size:0.3em;
    letter-spacing:0.05em;
    line-height:1;
    margin-bottom:0.05em;
  }

  /* Ruolo e voto sono UNA riga flex: due elementi inline indipendenti (inline-block
     su baseline contro inline-flex su middle, 34px contro 37) non si allineano mai.
     Qui si stirano alla stessa altezza qualunque cosa contengano, e a schermo
     stretto il voto va a capo con lo stesso gap invece di sbordare. */
  .chips-row{
    display:flex;
    flex-wrap:wrap;
    align-items:stretch;
    gap:10px;
    margin-bottom:22px;
  }
  .chips-row .role-chip{
    margin-bottom:0;
    display:inline-flex;
    align-items:center;
  }
  /* Il voto entra fra il ruolo (0.95s) e il pitch (1.1s), senza spostare gli altri.
     Parte da opacity:0 con `forwards`, come tutta la testata: il reset generico di
     prefers-reduced-motion in global.css lo porta comunque allo stato finale. */
  .grade-chip{
    display:inline-flex;
    align-items:baseline;
    gap:10px;
    margin:0;
    padding:6px 12px;
    border:2px solid var(--ink);
    background:var(--paper);
    text-decoration:none;
    font-size:11px;
    letter-spacing:0.09em;
    transition:background 0.15s ease, transform 0.15s ease;
    opacity:0;
    animation:riseIn 0.6s ease 1.02s forwards;
  }
  .grade-chip:hover{ transform:translateY(-1px); background:var(--paper-dark); }
  .grade-label{ opacity:0.75; }
  .grade-value{
    font-family:'Anton', sans-serif;
    font-size:19px;
    letter-spacing:0.02em;
    color:var(--seal);
    line-height:1;
  }
  .grade-verify{
    font-size:10px;
    opacity:0.6;
    border-left:1px solid var(--ink);
    padding-left:10px;
  }
  /* riseIn e i ritardi vengono da global.css: la sequenza d'entrata prosegue
     tag → nome → ruolo → voto → pitch → CTA → citazione. */
  .pitch{
    max-width:620px;
    font-size:19px;
    line-height:1.5;
    margin:0 0 20px;
    opacity:0;
    animation:riseIn 0.6s ease 1.1s forwards;
  }
  .hero-cta{
    display:inline-block;
    font-size:12px;
    letter-spacing:0.1em;
    text-decoration:none;
    background:var(--ink);
    color:var(--paper);
    border:2px solid var(--ink);
    padding:14px 20px;
    margin-bottom:28px;
    box-shadow:5px 5px 0 var(--orange);
    transition:transform 0.15s ease, box-shadow 0.15s ease;
    opacity:0;
    animation:riseIn 0.6s ease 1.25s forwards;
  }
  .hero-cta:hover{ transform:translate(2px,2px); box-shadow:3px 3px 0 var(--orange); }

  /* .kicker vive in global.css: qui solo la struttura figure/blockquote/cite. */
  .kicker{ animation-delay:1.4s; }
  .kicker blockquote{ margin:0; }
  .kicker figcaption{
    font-style:normal;
    font-size:11px;
    letter-spacing:0.08em;
    text-transform:uppercase;
    opacity:0.7;
    margin-top:10px;
  }
  .kicker cite{ font-style:normal; }
</style>
