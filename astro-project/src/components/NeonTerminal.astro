---
// `ls` elenca le sezioni che esistono davvero: elencarne una non renderizzata
// manderebbe l'utente su un'ancora morta.
const lsEntries = [
  'dossier',
  'percorso',
  'stack',
  'field-notes',
  'projects',
  'servizi',
  'contact',
];
const lsLine = lsEntries.map((e) => e + '/').join('  ');
---

<div class="neon-terminal-overlay" id="neon-terminal" data-ls={lsLine}>
  <div class="crt-screen">
    <div class="scanlines"></div>
    <div class="crt-flicker"></div>
    <button class="neon-close" id="neon-close" aria-label="Chiudi terminale">✕</button>
    <div class="crt-output" id="crt-output"></div>
    <div class="crt-inputline">
      <span class="crt-prompt">guest@bellingeri:~$</span>
      <input class="crt-input" id="crt-input" type="text" autocomplete="off" spellcheck="false" aria-label="Terminale interattivo" />
    </div>
  </div>
  {/* Turnstile invisibile per `ask`: stesso pattern e sitekey di Servizi.astro
      (data-execution="execute" → non parte al caricamento, solo al comando),
      ma container e callback dedicati — un secondo widget sulla stessa pagina,
      non quello del form contatti. Lo script cf-turnstile/api.js è già caricato
      da Servizi.astro (stessa pagina): duplicarlo qui non aggiungerebbe nulla. */}
  <div
    class="cf-turnstile"
    id="ask-turnstile"
    data-sitekey="0x4AAAAAADzdR4ih-HswrLQJ"
    data-execution="execute"
    data-callback="askTurnstileOk"
    data-error-callback="askTurnstileErr"
    data-action="turnstile-spin-v1"
  ></div>
</div>

<script>
  // ---- neon CRT terminal + konami trigger ----
  (function neonTerminal() {
    const overlay = document.getElementById('neon-terminal');
    const output = document.getElementById('crt-output');
    const input = document.getElementById('crt-input') as HTMLInputElement | null;
    const closeBtn = document.getElementById('neon-close');
    if (!overlay || !output || !input || !closeBtn) return;

    const cmdHistory: string[] = [];
    let historyPos = -1;

    // printLine accetta markup: le righe sono costanti scritte qui dentro.
    // Tutto ciò che digita l'utente passa PRIMA da esc(), altrimenti un
    // `<img src=x onerror=…>` incollato nel prompt esegue davvero.
    const esc = (s: string) =>
      s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string);

    function printLine(html: string, cls?: string | null) {
      const div = document.createElement('div');
      div.className = 'line' + (cls ? ' ' + cls : '');
      div.innerHTML = html;
      output!.appendChild(div);
      output!.scrollTop = output!.scrollHeight;
    }

    const REDIS_LOG = [
      '# contesto: sistema in produzione, layer di cache sotto carico',
      '- throughput query critica: baseline',
      '+ throughput query critica: <span class="yellow">41×</span> baseline',
      '# intervento: refactor completo del layer Redis',
      '# proposto ed eseguito in autonomia, zero downtime',
    ];

    const COMMANDS: Record<string, () => void> = {
      help() {
        printLine('Comandi disponibili:', 'magenta');
        const rows: [string, string][] = [
          ['whoami', 'chi sono'],
          ['ls', 'elenca le sezioni nascoste'],
          ['cat redis.log', 'il log del refactor 41×'],
          ['cat classified.txt', 'dossier riservato — declassificato'],
          ['projects', 'i progetti attivi'],
          ['servizi', 'come lavoriamo insieme'],
          ['contact', 'come contattarmi'],
          ['ask <domanda>', 'interroga il magazine (IA, con citazioni)'],
          ['neon', 'più neon. sempre più neon.'],
          ['matrix', 'per i nostalgici'],
          ['clear', 'pulisci lo schermo'],
          ['exit', "chiudi il terminale (o ESC)"],
        ];
        // larghezza colonna = comando più lungo + margine di 2 spazi (niente numero magico)
        const width = Math.max(...rows.map(([c]) => c.length)) + 2;
        // padding con &nbsp;: innerHTML + white-space non garantiscono la resa degli spazi ripetuti
        // esc(c): 'ask <domanda>' passa da innerHTML — senza escape il browser
        // mangia '<domanda>' come tag e la colonna si disallinea.
        rows.forEach(([c, d]) =>
          printLine('  <span class="yellow">' + esc(c) + '</span>' + '&nbsp;'.repeat(width - c.length) + d)
        );
      },
      whoami() {
        printLine('marco bellingeri — cloud platform &amp; ai security engineer');
        printLine('<span class="dim">freelance · casale monferrato, it · github.com/MK023</span>');
      },
      ls() {
        // Costante di build (data-ls), non input utente: printLine può riceverla così.
        printLine(esc(overlay!.dataset.ls || ''));
      },
      'cat redis.log'() {
        REDIS_LOG.forEach((l) => printLine(l));
      },
      'cat classified.txt'() {
        printLine('DECLASSIFICATO — accesso concesso.', 'magenta');
        printLine('&gt; calibro principale: Pilot Custom 845 Urushi rosso, pennino 18kt medio, Iroshizuku Kon-peki.');
        printLine('&gt; il refactor 41× è nato scoprendo una cache invalidata troppo spesso. il bug più costoso è spesso il più noioso.');
      },
      // Liste cablate: specchiano Projects.astro e Servizi.astro (ordine incluso).
      // Se cambiano quelli, cambia anche qui — il whoami insegnò che il terminale
      // è una superficie del posizionamento come le altre (PR #120).
      projects() {
        printLine('<span class="yellow">llm-council</span>   — council multi-modello anti-compiacenza, open source');
        printLine('<span class="yellow">torinoparking</span> — API parcheggi Torino → in arrivo su App Store');
        printLine('<span class="yellow">jobsearch</span>     — matching CV-offerta con Claude + server MCP');
        printLine('<span class="yellow">atlas</span>         — knowledge graph personale su Obsidian');
      },
      servizi() {
        printLine('<span class="yellow">security audit</span>      — a progetto');
        printLine('<span class="yellow">ai &amp; agent security</span> — a progetto');
        printLine('<span class="yellow">automazione ai</span>      — a progetto');
        printLine('<span class="yellow">cloud &amp; devops</span>      — retainer / giorno');
        printLine('<span class="yellow">pair &amp; advisory</span>     — a giornata');
        printLine('<span class="yellow">siti web</span>            — a progetto');
        printLine('<span class="dim">primo confronto sempre gratuito.</span>');
      },
      contact() {
        printLine('email:    <a href="mailto:mkdevpy@proton.me">mkdevpy@proton.me</a>');
        printLine('github:   <a href="https://github.com/MK023" target="_blank" rel="noopener">github.com/MK023</a>');
        printLine('linkedin: <a href="https://linkedin.com/in/marco-bellingeri" target="_blank" rel="noopener">linkedin.com/in/marco-bellingeri</a>');
        printLine('credly:   <a href="https://credly.com/users/marco-bellingeri" target="_blank" rel="noopener">credly.com/users/marco-bellingeri</a>');
      },
      ask() {
        // Nessun argomento: solo l'uso. La variante con domanda passa da
        // runAsk(), fuori dal registro — qui serve testo dinamico e async,
        // cose che COMMANDS (dispatch a chiave esatta) non gestisce.
        printLine('uso: ask &lt;domanda&gt;', 'dim');
      },
      neon() {
        document.documentElement.style.setProperty('filter', 'saturate(1.6)');
        printLine('saturazione neon: massima. (ricarica la pagina per tornare normale)', 'magenta');
      },
      matrix() {
        printLine('wake up, marco...', 'magenta');
        runMatrixRain(1800);
      },
      clear() {
        output!.innerHTML = '';
        // schermo vuoto senza appigli: stessa formula di chiusura di bootSequence()
        printLine("digita 'help' per i comandi disponibili.", 'dim');
      },
      exit() {
        close();
      },
      'sudo make me a sandwich'() {
        printLine('[sudo] password for guest: ', 'dim');
        printLine("Permission denied. <span class=\"dim\">(principio del privilegio minimo — chiedilo per bene.)</span>", 'magenta');
      },
    };

    // ---- ask: RAG dal vivo sul magazine, via /api/ask (Worker), gated da Turnstile ----
    const askTsEl = document.getElementById('ask-turnstile');

    // Turnstile richiama i callback per nome (data-callback/data-error-callback sul
    // widget): li traduco in una singola Promise per poter fare `await` dentro
    // runAsk(), come una normale chiamata di rete.
    // askAttivo copre l'INTERO runAsk (turnstile + fetch), non solo l'execute:
    // un secondo `ask` a metà volo sovrascriverebbe askResolve/askReject e la
    // prima richiesta resterebbe orfana — mai risolta, finally mai eseguito.
    let askAttivo = false;
    let askResolve: ((token: string) => void) | null = null;
    let askReject: ((err: Error) => void) | null = null;

    function eseguiAskTurnstile(): Promise<string> {
      return new Promise((resolve, reject) => {
        if (!window.turnstile?.execute) {
          // Script Turnstile non ancora arrivato (async) o bloccato: niente
          // callback in arrivo, quindi non resto in attesa all'infinito.
          reject(new Error('turnstile-assente'));
          return;
        }
        askResolve = resolve;
        askReject = reject;
        window.turnstile.execute(askTsEl ?? undefined);
      });
    }
    // I callback si azzerano dopo l'uso: un callback spurio doppio è un no-op.
    window.askTurnstileOk = (token: string) => {
      askResolve?.(token);
      askResolve = null; askReject = null;
    };
    window.askTurnstileErr = () => {
      askReject?.(new Error('turnstile-fallito'));
      askResolve = null; askReject = null;
    };

    // Una apertura del terminale = una conversazione = una session Langfuse.
    // Random, mai persistito: non identifica nessuno, lega solo le domande
    // della stessa visita (la telemetria non contiene i testi).
    const askSessionId = crypto.randomUUID();

    async function runAsk(domanda: string) {
      if (!domanda) { COMMANDS.ask(); return; }
      if (askAttivo) { printLine("c'è già una domanda in corso.", 'dim'); return; }
      askAttivo = true;
      printLine('pensando…', 'dim');
      try {
        const token = await eseguiAskTurnstile();
        const locale = document.documentElement.lang === 'en' ? 'en' : 'it';
        const r = await fetch('/api/ask', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ q: domanda, turnstile: token, locale, sid: askSessionId }),
        });
        if (!r.ok) throw new Error(String(r.status));
        const data = await r.json();

        // La risposta è output del modello: input non fidato. Passa SEMPRE da
        // esc(), mai innerHTML col testo grezzo — stesso principio di ogni
        // altra riga che arriva da fuori (vedi il commento su esc() più sopra).
        printLine(esc(String(data.answer ?? '')));

        const citations = Array.isArray(data.citations) ? data.citations : [];
        citations.forEach((c: { title?: string; url?: string }) => {
          // url è interno (/it/magazine/... o /en/magazine/...), generato dal
          // Worker: comunque esc() anche lui, per non fidarsi ciecamente di un
          // attributo href costruito con template string.
          const href = esc(String(c?.url ?? ''));
          const titolo = esc(String(c?.title ?? ''));
          // Niente style= inline: la CSP (style-src a hash) lo bloccherebbe a
          // runtime. Il colore vive in global.css (.crt-output a).
          printLine('→ <a href="' + href + '">' + titolo + '</a>');
        });

        if (data.disclosure) printLine(esc(String(data.disclosure)), 'dim');
      } catch {
        printLine('non riesco a rispondere ora. <span class="dim">riprova tra un minuto.</span>', 'magenta');
      } finally {
        askAttivo = false;
        window.turnstile?.reset?.(askTsEl ?? undefined);
      }
    }

    function runMatrixRain(duration: number) {
      const chars = 'アカサタナ01アイウエオABCDEFGHIJK';
      let elapsed = 0;
      const interval = setInterval(() => {
        let line = '';
        for (let i = 0; i < 48; i++) line += chars[Math.floor(Math.random() * chars.length)];
        printLine(line, 'magenta');
        elapsed += 90;
        if (elapsed >= duration) {
          clearInterval(interval);
          printLine('...still building real infrastructure though.', 'dim');
        }
      }, 90);
    }

    function bootSequence() {
      output!.innerHTML = '';
      const lines: [string, string | null][] = [
        ['BELLINGERI-OS v1.0 — CLOUD & SECURITY TERMINAL', 'magenta'],
        ['boot: checking perimeter defenses... <span class="yellow">OK</span>', null],
        ['boot: mounting /dev/redis... <span class="yellow">OK</span>', null],
        ['boot: loading pair-programming daemon... <span class="yellow">OK</span>', null],
        ['', null],
        ["digita 'help' per i comandi disponibili.", 'dim'],
      ];
      let i = 0;
      function next() {
        if (i >= lines.length) return;
        printLine(lines[i][0], lines[i][1]);
        i++;
        setTimeout(next, 140);
      }
      next();
    }

    function open() {
      overlay!.classList.add('open');
      bootSequence();
      setTimeout(() => input!.focus(), 200);
    }
    function close() {
      overlay!.classList.remove('open');
    }
    window.openNeonTerminal = open;

    closeBtn.addEventListener('click', close);
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { close(); return; }
      if (e.key === 'ArrowUp') {
        e.preventDefault();
        if (cmdHistory.length) { historyPos = Math.max(0, historyPos - 1); input!.value = cmdHistory[historyPos] || ''; }
        return;
      }
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        if (cmdHistory.length) { historyPos = Math.min(cmdHistory.length, historyPos + 1); input!.value = cmdHistory[historyPos] || ''; }
        return;
      }
      if (e.key !== 'Enter') return;

      const raw = input!.value;
      const cmd = raw.trim().toLowerCase();
      if (cmd.length) { cmdHistory.push(raw); historyPos = cmdHistory.length; }
      printLine('<span class="magenta">guest@bellingeri:~$</span> ' + esc(raw || ''));
      input!.value = '';

      if (!cmd) return;
      if (cmd.startsWith('ask ')) {
        // Unico comando con argomento libero: gli altri sono chiavi fisse nel
        // registro (es. 'cat redis.log'), qui la domanda è testo arbitrario
        // dell'utente e va tenuta fuori da COMMANDS. slice(4) su `raw`, non su
        // `cmd`, per non spedire la domanda tutta minuscola al modello.
        runAsk(raw.trim().slice(4).trim());
      } else if (COMMANDS[cmd]) {
        COMMANDS[cmd]();
      } else {
        printLine('comando non trovato: ' + esc(cmd) + " <span class=\"dim\">— prova 'help'</span>", 'magenta');
      }
    });

    // Konami code apre il terminale
    const sequence = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'b', 'a'];
    let pos = 0;
    document.addEventListener('keydown', (e) => {
      if (overlay!.classList.contains('open')) return;
      const key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
      if (key === sequence[pos]) {
        pos++;
        if (pos === sequence.length) { pos = 0; open(); }
      } else {
        pos = key === sequence[0] ? 1 : 0;
      }
    });
  })();
</script>
