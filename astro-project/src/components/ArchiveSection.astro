---
import { numeroSezione } from '../lib/sections';
import { useTranslations, dateLocale, defaultLang, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;
const t = useTranslations(lang);

const copy = {
  it: {
    title: 'Archivio',
    note: "Un numero nuovo ogni mese, generato in automatico: segnali dal mercato, mosse della concorrenza, novità normative. Nessuno lo scrive a mano — gira da solo, di notte, come dovrebbe fare l'infrastruttura buona.",
  },
  en: {
    title: 'Archive',
    note: 'A new issue every month, generated automatically: market signals, competitor moves, regulatory news. Nobody writes it by hand — it runs on its own, at night, the way good infrastructure should.',
  },
}[lang];

const strings = {
  loadingIndex: t('archive.loadingIndex'),
  loadingIssue: t('archive.loadingIssue'),
  openIssue: t('archive.openIssue'),
  source: t('archive.source'),
  unavailable: t('archive.unavailable'),
  locale: dateLocale[lang],
};
---

<section id="archive" class="reveal">
  <div class="section-head">
    <span class="num mono">{numeroSezione('archive')}</span>
    <h2 class="display">{copy.title}</h2>
  </div>
  <div class="archive-head">
    <p class="archive-note">{copy.note}</p>
  </div>
  <div class="archive-shelf" id="archive-shelf" data-strings={JSON.stringify(strings)}>
    <p class="archive-status">{strings.loadingIndex}</p>
  </div>
  <div class="issue-reader" id="issue-reader"></div>
</section>

<script>
  // ---- issue archive (alimentato da /data/issues/, generato ogni mese dalla pipeline engine/) ----
  type Signal = {
    category: 'competitor' | 'market' | 'security';
    label: string;
    headline: string;
    summary: string;
    source_name?: string;
    source_url?: string;
  };
  type Issue = { id: string; number: number; title: string; date: string; signals: Signal[] };
  type IndexEntry = { id: string; number: number; title: string; date: string };

  (function issueArchive() {
    const shelf = document.getElementById('archive-shelf');
    const reader = document.getElementById('issue-reader');
    if (!shelf || !reader) return;

    const S = JSON.parse(shelf.dataset.strings || '{}');

    // Nessun numero finto di riserva. Questa sezione è renderizzata solo quando
    // index.json contiene almeno un numero vero (vedi src/lib/issues.ts): se poi
    // il fetch fallisce, si dice che non è disponibile. Un segnaposto spacciato
    // per numero è la sola bugia che questa pagina non può permettersi.
    let index: { issues: IndexEntry[] } | null = null;
    let activeId: string | null = null;

    const CATEGORIES = ['competitor', 'market', 'security'] as const;
    function tagClass(cat: Signal['category']) {
      // La categoria arriva da JSON generato: non la si concatena mai in una
      // classe senza averla prima ristretta ai valori attesi.
      const safe = CATEGORIES.includes(cat) ? cat : 'security';
      return 'signal-tag ' + safe;
    }

    function status(el: HTMLElement, text: string) {
      const p = document.createElement('p');
      p.className = 'archive-status';
      p.textContent = text;
      el.replaceChildren(p);
    }

    function renderShelf() {
      if (!shelf || !index) return;
      shelf.replaceChildren();
      index.issues.slice().reverse().forEach((issue) => {
        const spine = document.createElement('div');
        spine.className = 'issue-spine' + (issue.id === activeId ? ' active' : '');
        spine.setAttribute('role', 'button');
        spine.setAttribute('tabindex', '0');
        const month = new Date(issue.date).toLocaleDateString(S.locale, { month: 'short', year: 'numeric' });
        spine.setAttribute('aria-label', S.openIssue + ' ' + issue.number + ', ' + month);

        const n = document.createElement('div');
        n.className = 'n';
        n.textContent = 'N.' + String(issue.number).padStart(2, '0');
        const m = document.createElement('div');
        m.className = 'm';
        m.textContent = month.toUpperCase();
        spine.append(n, m);

        spine.addEventListener('click', () => openIssue(issue.id));
        spine.addEventListener('keydown', (e: KeyboardEvent) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openIssue(issue.id); }
        });
        shelf.appendChild(spine);
      });
    }

    function renderReader(issue: Issue) {
      if (!reader) return;
      // Tutto il contenuto del numero è testo non fidato (generato da un LLM,
      // committato come JSON): costruito nodo per nodo, mai via innerHTML.
      reader.replaceChildren();

      const head = document.createElement('div');
      head.className = 'issue-reader-head';
      const h3 = document.createElement('h3');
      h3.className = 'display';
      h3.textContent = issue.title;
      const date = document.createElement('span');
      date.className = 'date mono';
      date.textContent = new Date(issue.date).toLocaleDateString(S.locale, { day: 'numeric', month: 'long', year: 'numeric' });
      head.append(h3, date);
      reader.appendChild(head);

      issue.signals.forEach((s) => {
        const card = document.createElement('div');
        card.className = 'signal-card';

        const tag = document.createElement('span');
        tag.className = tagClass(s.category);
        tag.textContent = s.label;

        const headline = document.createElement('h4');
        headline.textContent = s.headline;

        const summary = document.createElement('p');
        summary.textContent = s.summary;

        card.append(tag, headline, summary);

        // Una fonte è per definizione esterna e assoluta. Senza base, `new URL`
        // rifiuta gli URL relativi: "esempio.com/report" diventerebbe altrimenti
        // un link al nostro stesso dominio. Il filtro sul protocollo blocca
        // javascript: e mailto:.
        if (s.source_url) {
          try {
            const url = new URL(s.source_url);
            if (url.protocol === 'http:' || url.protocol === 'https:') {
              const link = document.createElement('a');
              link.href = url.href;
              link.target = '_blank';
              link.rel = 'noopener';
              link.textContent = (s.source_name || S.source) + ' ↗';
              card.appendChild(link);
            }
          } catch (e) {}
        }

        reader.appendChild(card);
      });
    }

    async function openIssue(id: string) {
      activeId = id;
      renderShelf();
      if (reader) status(reader, S.loadingIssue + ' ' + id + '…');
      try {
        const res = await fetch('/data/issues/' + encodeURIComponent(id) + '.json', { cache: 'no-store' });
        if (!res.ok) throw new Error('not found');
        renderReader((await res.json()) as Issue);
      } catch (e) {
        if (reader) status(reader, S.unavailable);
      }
    }

    async function loadIndex() {
      if (shelf) status(shelf, S.loadingIndex);
      try {
        // L'indice cambia quando la pipeline pubblica un numero. Senza no-store
        // resterebbe nella cache HTTP (/data/* ha max-age=3600) e un visitatore
        // di ritorno non vedrebbe il numero nuovo: non c'è più un bottone di
        // ricarica a rimediare.
        const res = await fetch('/data/issues/index.json', { cache: 'no-store' });
        if (!res.ok) throw new Error('not found');
        index = await res.json();
        if (!index || !index.issues || index.issues.length === 0) throw new Error('empty');
      } catch (e) {
        if (shelf) status(shelf, S.unavailable);
        if (reader) reader.replaceChildren();
        return;
      }
      activeId = index.issues[index.issues.length - 1].id;
      renderShelf();
      openIssue(activeId);
    }

    loadIndex();
  })();
</script>
