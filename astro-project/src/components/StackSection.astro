---
import { numeroSezione } from '../lib/sections';
import Newsstand from './Newsstand.astro';
import { defaultLang, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;

const copy = {
  it: {
    title: 'Stack',
    certsHead: 'Certificazioni · verificabili su Credly',
    certAnthropic: 'Anthropic · 15 corsi · 2026',
    newTab: 'si apre in una nuova scheda',
    cards: [
      ['CORE', 'Python & Backend', 'La lingua di casa: backend e API con Clean Architecture e DDD — FastAPI, Flask, Falcon.'],
      ['FRONT', 'Frontend', 'Astro e Vite — questo sito incluso; React e TypeScript quando serve una SPA.'],
      ['INFRA', 'Cloud & IaC', 'AWS (Lambda, SQS, S3, IAM, VPC), Kubernetes / K3s, Terraform, Cloudflare Tunnel.'],
      ['SEC', 'Security', 'OWASP hardening, crittografia PII (AES-256), security gate in CI: Bandit, CodeQL, Gitleaks.'],
      ['DATA', 'Database', 'PostgreSQL + PostGIS, Redis, MongoDB, SQLite FTS5 — geospaziale e caching ad alte prestazioni.'],
      ['OPS', 'DevOps & Observability', 'Docker e K3s, CI/CD su GitHub Actions; Sentry, Langfuse, Prometheus e Grafana.'],
      ['AI', 'AI & Agenti', 'Claude API, Model Context Protocol (MCP), Groq, HuggingFace Transformers.'],
    ],
  },
  en: {
    title: 'Stack',
    certsHead: 'Certifications · verifiable on Credly',
    certAnthropic: 'Anthropic · 15 courses · 2026',
    newTab: 'opens in a new tab',
    cards: [
      ['CORE', 'Python & Backend', 'Home turf: back-ends and APIs built on Clean Architecture and DDD — FastAPI, Flask, Falcon.'],
      ['FRONT', 'Frontend', 'Astro and Vite — this site included; React and TypeScript when a SPA is called for.'],
      ['INFRA', 'Cloud & IaC', 'AWS (Lambda, SQS, S3, IAM, VPC), Kubernetes / K3s, Terraform, Cloudflare Tunnel.'],
      ['SEC', 'Security', 'OWASP hardening, PII encryption (AES-256), CI security gates: Bandit, CodeQL, Gitleaks.'],
      ['DATA', 'Database', 'PostgreSQL + PostGIS, Redis, MongoDB, SQLite FTS5 — geospatial and high-performance caching.'],
      ['OPS', 'DevOps & Observability', 'Docker and K3s, CI/CD on GitHub Actions; Sentry, Langfuse, Prometheus and Grafana.'],
      ['AI', 'AI & Agents', 'Claude API, Model Context Protocol (MCP), Groq, HuggingFace Transformers.'],
    ],
  },
}[lang];

// Certificazioni rese come PILA da edicola (Newsstand): impilate e compatte non
// fanno "muro di badge junior", e si aprono a ventaglio. Link al profilo Credly,
// dove le verificabili stanno tutte. L'Anthropic Academy 2026 (15 corsi) sposta
// il segnale sull'AI attuale.
const CREDLY = 'https://credly.com/users/marco-bellingeri';
const certs = [
  { label: 'IT Specialist – Cybersecurity', sub: 'Cisco Networking Academy · 2022', href: CREDLY },
  { label: 'Linux Essentials', sub: 'Linux Professional Institute · 2022', href: CREDLY },
  { label: 'GitHub Foundations', sub: 'GitHub · 2025', href: CREDLY },
  { label: 'MongoDB Python Developer Path', sub: 'MongoDB · 2024', href: CREDLY },
  { label: 'Python PCEP [30-02]', sub: 'Python Institute · 2024', href: CREDLY },
  { label: 'Containers & Kubernetes Essentials', sub: 'IBM · 2024', href: CREDLY },
  { label: 'Docker Essentials', sub: 'IBM · 2024', href: CREDLY },
  { label: 'Anthropic Academy', sub: copy.certAnthropic, href: CREDLY },
];
---

<section id="stack" class="reveal">
  <div class="section-head">
    <span class="num mono">{numeroSezione('stack')}</span>
    <h2 class="display">{copy.title}</h2>
  </div>
  <div class="stack-grid reveal-stagger">
    {copy.cards.map(([tag, title, body]) => (
      <div class="stack-card" data-tag={tag}>
        <h3>{title}</h3>
        <p>{body}</p>
      </div>
    ))}
  </div>

  <Newsstand head={copy.certsHead} items={certs} newTab={copy.newTab} />
</section>
