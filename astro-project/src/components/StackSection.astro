---
import { numeroSezione } from '../lib/sections';
import Newsstand from './Newsstand.astro';
import { defaultLang, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;

const copy = {
  it: {
    title: 'Stack',
    certsHead: 'Certificazioni · ognuna verificabile alla fonte',
    certAnthropic: 'Anthropic · 15 corsi · 2026',
    newTab: 'si apre in una nuova scheda',
    cards: [
      ['CORE', 'Python & Backend', 'La lingua di casa: backend e API con Clean Architecture e DDD (FastAPI, Flask, Falcon). Frontend: Astro e Vite, questo sito incluso; React e TypeScript quando serve una SPA.'],
      ['SEC', 'Security', 'OWASP hardening, crittografia PII (AES-256), threat modeling e audit scritto nel repo; security gate in CI: Bandit, CodeQL, Gitleaks.'],
      ['AI-SEC', 'AI Security', 'OWASP LLM Top 10 su un RAG che sta in produzione: difesa dalla prompt injection sui contenuti che arrivano da fuori, LLM-as-a-judge come gate in CI, trasparenza AI Act (art. 50), MITRE ATLAS come mappa delle minacce.'],
      ['AI', 'AI & Agenti', 'RAG con citazioni (embedding Voyage), guardrail e revisione umana dentro il flusso, evals: su Claude API e Model Context Protocol (MCP).'],
      ['SUPPLY', 'Supply Chain', 'SBOM CycloneDX e attestation di provenance firmata (OIDC keyless) a ogni deploy, dipendenze pinnate per SHA, zizmor sui workflow, gitleaks su tutta la storia.'],
      ['INFRA', 'Cloud & IaC', 'AWS (Lambda, SQS, S3, IAM, VPC), Kubernetes / K3s, Terraform, Cloudflare Tunnel.'],
      ['DATA', 'Database', 'PostgreSQL + PostGIS, Redis, MongoDB, SQLite FTS5 — geospaziale e caching ad alte prestazioni.'],
      ['OPS', 'DevOps & Observability', 'Docker e K3s, CI/CD su GitHub Actions; Sentry, Langfuse, Prometheus e Grafana.'],
    ],
  },
  en: {
    title: 'Stack',
    certsHead: 'Certifications · each verifiable at the source',
    certAnthropic: 'Anthropic · 15 courses · 2026',
    newTab: 'opens in a new tab',
    cards: [
      ['CORE', 'Python & Backend', 'Home turf: back-ends and APIs built on Clean Architecture and DDD (FastAPI, Flask, Falcon). Frontend: Astro and Vite, this site included; React and TypeScript when a SPA is called for.'],
      ['SEC', 'Security', 'OWASP hardening, PII encryption (AES-256), threat modeling and a written audit in the repo; CI security gates: Bandit, CodeQL, Gitleaks.'],
      ['AI-SEC', 'AI Security', 'OWASP LLM Top 10 on a RAG that runs in production: prompt injection defence on content coming from outside, LLM-as-a-judge as a CI gate, EU AI Act transparency (art. 50), MITRE ATLAS as the threat map.'],
      ['AI', 'AI & Agents', 'RAG with citations (Voyage embeddings), guardrails and human review inside the flow, evals: on Claude API and the Model Context Protocol (MCP).'],
      ['SUPPLY', 'Supply Chain', 'CycloneDX SBOM and signed provenance attestation (keyless OIDC) on every deploy, dependencies pinned by SHA, zizmor on the workflows, gitleaks across the whole history.'],
      ['INFRA', 'Cloud & IaC', 'AWS (Lambda, SQS, S3, IAM, VPC), Kubernetes / K3s, Terraform, Cloudflare Tunnel.'],
      ['DATA', 'Database', 'PostgreSQL + PostGIS, Redis, MongoDB, SQLite FTS5 — geospatial and high-performance caching.'],
      ['OPS', 'DevOps & Observability', 'Docker and K3s, CI/CD on GitHub Actions; Sentry, Langfuse, Prometheus and Grafana.'],
    ],
  },
}[lang];

// Certificazioni rese come PILA da edicola (Newsstand): impilate e compatte non
// fanno "muro di badge junior", e si aprono a ventaglio.
// CURATA A 10 — tetto deciso da Marco (24-07-2026), non si sfora: la pila
// racconta la DIREZIONE (AI security, supply chain, zero trust), la storia
// professionale la racconta il Percorso. Ogni voce linka la SUA verifica:
// PDF Linux Foundation con ID certificato, pagine di verifica Securiti e
// AttackIQ, Credly per il resto. Ciò che esce dalla pila resta sul profilo
// Credly (linkato nel footer e nel terminale), non sparisce dal mondo.
const CREDLY = 'https://credly.com/users/marco-bellingeri';
const LF_CERT = (id: string) =>
  `https://ti-user-certificates.s3.amazonaws.com/e0df7fbf-a057-42af-8a1f-590912be5460/4dde14c1-ec30-4b56-ba8d-50fc17ccd6d9-marco-bellingeri-${id}-certificate.pdf`;
const certs = [
  { label: 'AI Security & Governance', sub: 'Securiti Education · 2026', href: 'https://education.securiti.ai/verification/14B137A88-14B135575-144EF5CD6/' },
  { label: 'Foundations of AI Security', sub: 'AttackIQ Academy · 2026', href: 'https://www.academy.attackiq.com/certificates/certificate-template?resource=11843&type=course&title=Foundations%20of%20AI%20Security&cert_id=6711' },
  { label: 'Secure AI/ML-Driven Software Development', sub: 'OpenSSF · Linux Foundation · 2026', href: LF_CERT('c13ddfe5-838d-4746-86b2-19c680ca9756') },
  { label: 'Automating Supply Chain Security: SBOMs & Signatures', sub: 'OpenSSF · Linux Foundation · 2026', href: LF_CERT('a293b447-ef0e-49be-815c-00e903d807b2') },
  { label: 'Understanding the EU Cyber Resilience Act (CRA)', sub: 'OpenSSF · Linux Foundation · 2026', href: LF_CERT('9302380f-be95-4491-acef-0382ba853655') },
  { label: 'Introduction to Zero Trust', sub: 'Linux Foundation · 2026', href: LF_CERT('5f6c1e79-a93d-4cef-8761-91e6f8a3da77') },
  { label: 'Anthropic Academy', sub: copy.certAnthropic, href: CREDLY },
  { label: 'Google AI Professional Certificate', sub: 'Google Career Certificates · 2026', href: CREDLY },
  { label: 'Using Voyage Models with MongoDB', sub: 'MongoDB · 2026', href: CREDLY },
  { label: 'GitHub Foundations', sub: 'GitHub · 2025', href: CREDLY },
];
---

<section id="stack" class="reveal">
  <div class="section-head">
    <span class="num mono">{numeroSezione('stack')}</span>
    <h2 class="display">{copy.title}</h2>
  </div>
  <div class="stack-grid reveal-stagger">
    {copy.cards.map(([tag, title, body]) => (
      <div class="stack-card" data-tag={tag}>
        <h3>{title}</h3>
        <p>{body}</p>
      </div>
    ))}
  </div>

  <Newsstand head={copy.certsHead} items={certs} newTab={copy.newTab} />
</section>
