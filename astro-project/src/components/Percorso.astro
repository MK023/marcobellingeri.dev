---
import { numeroSezione } from '../lib/sections';
import { defaultLang, type Lang } from '../i18n/ui';

const lang = (Astro.currentLocale ?? defaultLang) as Lang;

type Role = {
  when: string;
  co: string;
  role: string;
  desc: string;
  // `hl` = tag in evidenza (fondo arancio): il risultato che vale la pena leggere per primo.
  tags: { label: string; hl?: boolean }[];
};

const copy: Record<Lang, { title: string; roles: Role[] }> = {
  it: {
    title: 'Percorso',
    roles: [
      {
        when: '2026 — oggi',
        co: 'VETRERIA MONFERRINA · REMOTO',
        role: 'Full Stack & AI Engineer',
        desc: 'Sito di produzione (Astro + Sanity) e un agente IA per SEO/AEO con RAG su Supabase e governance secondo l\'AI Act.',
        tags: [{ label: 'Astro' }, { label: 'Supabase + pgvector' }, { label: 'AI Act' }],
      },
      {
        when: '2025 — 2026',
        co: 'FAIRFIELD S.p.A. — Figline e Incisa Valdarno (FI), Remoto',
        role: 'Full Stack Engineer',
        desc: 'Piattaforma enterprise per il recupero crediti, full-stack: backend Python (Clean/DDD) su AWS serverless e SPA React/TypeScript multi-ruolo.',
        tags: [{ label: 'REFACTOR REDIS', hl: true }, { label: 'AWS' }, { label: 'React / TS' }],
      },
      {
        when: '2025',
        co: 'GECO S.R.L. · GALLIATE (NO)',
        role: 'Software Engineer',
        desc: 'Software per infrastrutture critiche: supervisione video 24/7 della Metropolitana C di Roma e diagnostica di rete enterprise per Etihad Airways (Scapy).',
        tags: [{ label: 'Python' }, { label: 'Scapy' }],
      },
    ],
  },
  en: {
    title: 'Career',
    roles: [
      {
        when: '2026 — present',
        co: 'VETRERIA MONFERRINA · REMOTE',
        role: 'Full Stack & AI Engineer',
        desc: 'A production site (Astro + Sanity) and an AI agent for SEO/AEO with RAG on Supabase and AI Act governance.',
        tags: [{ label: 'Astro' }, { label: 'Supabase + pgvector' }, { label: 'AI Act' }],
      },
      {
        when: '2025 — 2026',
        co: 'FAIRFIELD S.p.A. — Figline e Incisa Valdarno (FI), Remote',
        role: 'Full Stack Engineer',
        desc: 'Full-stack work on an enterprise debt-collection platform: a Python back-end (Clean/DDD) on AWS serverless and a multi-role React/TypeScript SPA.',
        tags: [{ label: 'REDIS REFACTOR', hl: true }, { label: 'AWS' }, { label: 'React / TS' }],
      },
      {
        when: '2025',
        co: 'GECO S.R.L. · GALLIATE (NO)',
        role: 'Software Engineer',
        desc: 'Software for critical infrastructure: 24/7 video supervision for Rome Metro Line C and enterprise network diagnostics for Etihad Airways (Scapy).',
        tags: [{ label: 'Python' }, { label: 'Scapy' }],
      },
    ],
  },
};

const { title, roles } = copy[lang];
---

<section id="percorso" class="reveal">
  <div class="section-head">
    <span class="num mono">{numeroSezione('percorso')}</span>
    <h2 class="display">{title}</h2>
  </div>
  <div class="tl2">
    <div class="tl2-fill" aria-hidden="true"></div>
    {roles.map((r) => (
      <div class="tl2-item">
        <div class="tl2-when mono">{r.when}<span class="co">{r.co}</span></div>
        <div>
          <h3 class="tl2-role">{r.role}</h3>
          <p class="tl2-desc">{r.desc}</p>
          <div class="tl2-tags">
            {r.tags.map((tag) => (
              <span class={tag.hl ? 'tl2-tag hl' : 'tl2-tag'}>{tag.label}</span>
            ))}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>

<script>
  // ---- la spina della timeline si disegna mentre scorri ----
  (function timelineSpine() {
    const tl = document.querySelector<HTMLElement>('.tl2');
    if (!tl) return;
    const fill = tl.querySelector<HTMLElement>('.tl2-fill');
    const items = Array.from(tl.querySelectorAll<HTMLElement>('.tl2-item'));

    // Con reduced-motion la spina resta piena e i pallini accesi: nessun effetto
    // legato allo scroll, ma la timeline si legge comunque come "percorsa".
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      if (fill) fill.style.height = '100%';
      items.forEach((it) => it.classList.add('reached'));
      return;
    }

    function update() {
      const rect = tl!.getBoundingClientRect();
      const mid = (window.innerHeight || 800) * 0.62;
      const height = Math.max(0, tl!.offsetHeight - 20);
      const passed = Math.min(Math.max(mid - (rect.top + 10), 0), height);
      if (fill) fill.style.height = passed + 'px';
      items.forEach((it) => {
        it.classList.toggle('reached', it.getBoundingClientRect().top + 14 <= mid);
      });
    }

    // Lo scroll può emettere decine di eventi per frame: il lavoro di layout si
    // fa una volta sola, nel frame successivo.
    let queued = false;
    function onScroll() {
      if (queued) return;
      queued = true;
      requestAnimationFrame(() => { queued = false; update(); });
    }

    update();
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll);
  })();
</script>
